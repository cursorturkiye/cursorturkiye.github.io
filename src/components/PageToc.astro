---
interface TocItem {
  id: string;
  labelEn: string;
  labelTr: string;
}

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

<nav class="page-toc mb-10 -mt-2 overflow-x-auto scrollbar-hide" aria-label="Table of contents">
  <ul class="flex flex-wrap gap-2 text-sm" role="list">
    {items.map((item) => (
      <li>
        <a
          href={`#${item.id}`}
          class="inline-block rounded-full border border-[#252525] bg-[#141414] px-3.5 py-1.5 text-[#999999] hover:text-white hover:border-white/20 transition-colors whitespace-nowrap"
        >
          <span class="lang-en">{item.labelEn}</span>
      <span class="lang-tr">{item.labelEn}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>


---
interface EventData {
  title: string;
  titleAr?: string;
  date: Date;
  location: string;
  locationAr?: string;
  lumaUrl?: string;
  description: string;
  descriptionAr?: string;
  type: "meetup" | "hackathon" | "workshop" | "build";
  status: "backlog" | "informed" | "venue-pending" | "register-open" | "register-closed" | "concluded" | "canceled";
  speakers?: string[];
  slides?: string[];
  venue?: string;
}

interface Props {
  event: EventData;
}

const { event } = Astro.props;

const day = event.date.getDate();
const dayAr = event.date.getDate().toLocaleString("ar-SA");
const monthShort = event.date.toLocaleDateString("en-US", { month: "short" }).toUpperCase();
const monthShortAr = event.date.toLocaleDateString("ar-SA", { month: "short" });
const year = event.date.getFullYear();
const yearAr = event.date.getFullYear().toLocaleString("ar-SA");
const weekday = event.date.toLocaleDateString("en-US", { weekday: "long" });
const weekdayAr = event.date.toLocaleDateString("ar-SA", { weekday: "long" });

const slides = event.slides ?? [];
const isCanceled = event.status === "canceled";

const statusLabels: Record<string, { en: string; ar: string }> = {
  backlog: { en: "Backlog", ar: "قيد التخطيط" },
  informed: { en: "Informed", ar: "تم الإبلاغ" },
  "venue-pending": { en: "Venue Pending", ar: "بانتظار المكان" },
  "register-open": { en: "Register Open", ar: "التسجيل مفتوح" },
  "register-closed": { en: "Registration Closed", ar: "التسجيل مغلق" },
  concluded: { en: "Concluded", ar: "انتهت" },
  canceled: { en: "Canceled", ar: "ملغي" },
};
const statusLabel = statusLabels[event.status] ?? statusLabels.backlog;

const typeAccent: Record<string, { rgb: string; labelEn: string; labelAr: string }> = {
  meetup: { rgb: "59, 130, 246", labelEn: "Meetup", labelAr: "لقاء" },
  hackathon: { rgb: "245, 158, 11", labelEn: "Hackathon", labelAr: "هاكاثون" },
  workshop: { rgb: "16, 185, 129", labelEn: "Workshop", labelAr: "ورشة عمل" },
  build: { rgb: "168, 85, 247", labelEn: "Build", labelAr: "بناء" },
};
const accent = typeAccent[event.type] ?? typeAccent.meetup;
---

<article class={`event-card card animate-on-scroll${isCanceled ? " event-canceled" : ""}`} style={`--card-accent: ${accent.rgb};`}>
  <!-- Top accent edge -->
  <div class="card-accent-edge" aria-hidden="true"></div>

  <!-- Date strip -->
  <div class="date-strip">
    <div class="date-main">
      <span class="date-day">
        <span class="lang-en">{day}</span>
        <span class="lang-ar">{dayAr}</span>
      </span>
      <div class="date-details">
        <span class="date-month-year">
          <span class="lang-en">{monthShort} {year}</span>
          <span class="lang-ar">{monthShortAr} {yearAr}</span>
        </span>
        <span class="date-weekday">
          <span class="lang-en">{weekday}</span>
          <span class="lang-ar">{weekdayAr}</span>
        </span>
      </div>
    </div>
    <div class="date-badges">
      <span class={`badge badge-${event.type}`}>
        <span class="lang-en">{accent.labelEn}</span>
        <span class="lang-ar">{accent.labelAr}</span>
      </span>
      <span class={`badge badge-status-${event.status}`}>
        <span class="lang-ar">{statusLabel.ar}</span>
        <span class="lang-en">{statusLabel.en}</span>
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="event-body">
    <h3 class="event-title">
      <span class="lang-ar">{event.titleAr ?? event.title}</span>
      <span class="lang-en">{event.title}</span>
    </h3>

    <div class="event-meta">
      <span class="meta-item">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 14s-5-4.5-5-8a5 5 0 1 1 10 0c0 3.5-5 8-5 8z" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span class="lang-ar">{event.locationAr ?? event.location}</span>
        <span class="lang-en">{event.location}</span>
        {event.venue && <span class="event-venue">· {event.venue}</span>}
      </span>
      {
        event.speakers && event.speakers.length > 0 && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="lang-ar">{event.speakers.join("، ")}</span>
            <span class="lang-en">{event.speakers.join(", ")}</span>
          </span>
        )
      }
    </div>

    <p class="event-description">
      <span class="lang-ar">{event.descriptionAr ?? event.description}</span>
      <span class="lang-en">{event.description}</span>
    </p>

    <div class="event-card-footer">
      {
        event.status === "register-open" && event.lumaUrl ? (
          <a href={event.lumaUrl} class="btn btn-primary btn-sm" target="_blank" rel="noreferrer">
            <span class="lang-ar">سجّل الآن</span>
            <span class="lang-en">Register</span>
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ) : event.status === "register-closed" ? (
          <span class="registration-closed-label">
            <span class="lang-ar">التسجيل مغلق</span>
            <span class="lang-en">Registration Closed</span>
          </span>
        ) : slides.length > 0 ? (
          <div class="slides-links">
            <span class="slides-label">
              <span class="lang-ar">العروض</span>
              <span class="lang-en">Slides</span>
            </span>
            {slides.map((slide, index) => (
              <a href={slide} target="_blank" rel="noreferrer" class="slide-link">
                <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {index + 1}
              </a>
            ))}
          </div>
        ) : null
      }
    </div>
  </div>
</article>

<style>
  /* ── Card Shell ── */
  .event-card {
    padding: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .event-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      160deg,
      rgba(var(--card-accent), 0.2) 0%,
      transparent 40%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .event-card:hover::before {
    opacity: 1;
  }

  .event-card:hover {
    transform: translateY(-2px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.25),
      0 0 50px rgba(var(--card-accent), 0.04);
  }

  /* ── Accent top edge ── */
  .card-accent-edge {
    height: 2px;
    background: linear-gradient(
      90deg,
      rgba(var(--card-accent), 0.7),
      rgba(var(--card-accent), 0.15) 80%,
      transparent
    );
  }

  html[dir="rtl"] .card-accent-edge {
    background: linear-gradient(
      -90deg,
      rgba(var(--card-accent), 0.7),
      rgba(var(--card-accent), 0.15) 80%,
      transparent
    );
  }

  /* ── Date Strip ── */
  .date-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: rgba(var(--card-accent), 0.03);
    border-bottom: 1px solid var(--border);
    gap: 0.75rem;
  }

  .date-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .date-day {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    color: rgb(var(--card-accent));
    min-width: 2.5ch;
    text-align: center;
    letter-spacing: -0.03em;
  }

  .date-details {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .date-month-year {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .date-weekday {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-tertiary);
    line-height: 1.2;
  }

  /* ── Body ── */
  .event-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.15rem 1.25rem 1.25rem;
  }

  .event-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    font-size: 0.84rem;
  }

  .meta-item svg {
    flex-shrink: 0;
    color: var(--text-tertiary);
  }

  .event-venue {
    color: var(--text-tertiary);
  }

  .event-description {
    color: var(--text-secondary);
    font-size: 0.84rem;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Footer ── */
  .event-card-footer {
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .btn-sm {
    padding: 0.55rem 1.15rem;
    font-size: 0.82rem;
    border-radius: var(--radius-sm);
  }

  .slides-links {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .slides-label {
    color: var(--text-tertiary);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .slide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem 0.55rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 600;
    transition: all var(--transition-fast);
  }

  .slide-link:hover {
    background: var(--surface-hover);
    border-color: var(--accent);
    color: var(--accent-hover);
  }

  /* ── Date badges row ── */
  .date-badges {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  /* ── Canceled state ── */
  .event-canceled {
    opacity: 0.55;
  }

  .event-canceled .event-title {
    text-decoration: line-through;
    text-decoration-color: var(--text-tertiary);
  }

  /* ── Registration closed label ── */
  .registration-closed-label {
    color: var(--text-tertiary);
    font-size: 0.82rem;
    font-weight: 600;
  }
</style>

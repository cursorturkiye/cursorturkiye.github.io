---
import {
  getNonAmbassadorSpeakers,
  getAllPartnersWithEvents,
  getAllSupporters,
  getAffiliationPartnerDisplay,
} from "@/utils/people";
import { contributorRoleBadgeClass } from "@/utils/contributor-role-badge";
import PageToc from "@/components/PageToc.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { localizedPath } from "@/utils/i18n-path";

const pagePath = Astro.url.pathname;

const roleOrder = ["official", "community-partner", "venue-host", "past-community-partner"] as const;

const speakers = await getNonAmbassadorSpeakers();
const allPartners = await getAllPartnersWithEvents();
const supporters = getAllSupporters();

const speakerAffiliation = new Map<
  string,
  NonNullable<ReturnType<typeof getAffiliationPartnerDisplay>>
>();
for (const s of speakers) {
  if (!s.affiliationPartnerSlug) continue;
  const d = getAffiliationPartnerDisplay(s.affiliationPartnerSlug);
  if (d) speakerAffiliation.set(s.slug, d);
}

const supporterAffiliation = new Map<
  string,
  NonNullable<ReturnType<typeof getAffiliationPartnerDisplay>>
>();
for (const s of supporters) {
  if (!s.affiliation) continue;
  const d = getAffiliationPartnerDisplay(s.affiliation);
  if (d) supporterAffiliation.set(s.name, d);
}

const roleLabelEn: Record<string, string> = {
  "official": "Official",
  "community-partner": "Community Partners",
  "venue-host": "Venue Hosts",
  "past-community-partner": "Past Partners",
};

const roleLabelTr: Record<string, string> = {
  "official": "Türkçe Türkçe",
  "community-partner": "Türkçe Topluluk",
  "venue-host": "Türkçe Türkçe",
  "past-community-partner": "Türkçe Türkçe",
};

const roleBadgeEn: Record<string, string> = {
  "official": "Official",
  "community-partner": "Community Partner",
  "venue-host": "Venue Host",
  "past-community-partner": "Past Partner",
};

const roleBadgeTr: Record<string, string> = {
  "official": "Türkçe",
  "community-partner": "Topluluk Ortagi",
  "venue-host": "Türkçe",
  "past-community-partner": "Türkçe Türkçe",
};

const grouped = roleOrder
  .map((role) => ({
    role,
    partners: allPartners.filter((p) => p.role === role),
  }))
  .filter((g) => g.partners.length > 0);

const avatarColors = [
  "from-blue-500/20 to-blue-600/10 text-blue-400",
  "from-purple-500/20 to-purple-600/10 text-purple-400",
  "from-green-500/20 to-green-600/10 text-green-400",
  "from-amber-500/20 to-amber-600/10 text-amber-400",
  "from-rose-500/20 to-rose-600/10 text-rose-400",
  "from-cyan-500/20 to-cyan-600/10 text-cyan-400",
  "from-indigo-500/20 to-indigo-600/10 text-indigo-400",
];

const tocItems = [
  { id: "speakers", labelEn: "Speakers", labelTr: "Türkçe" },
  ...(supporters.length > 0 ? [{ id: "supporters", labelEn: "Supporters", labelTr: "Türkçe" }] : []),
  { id: "community-partners", labelEn: "Community Partners", labelTr: "Türkçe Topluluk" },
];
---

<section id="thankyou">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">
    <!-- Hero -->
    <div class="max-w-4xl mx-auto text-center mb-20">
      <h1 class="text-4xl md:text-5xl font-semibold text-white mb-6">
        <span class="lang-en">Thank You</span>
      <span class="lang-tr">Thank You</span>
      </h1>
      <p class="text-xl text-[#999999] leading-relaxed">
        <span class="lang-en">To everyone who helped build this community</span>
      <span class="lang-tr">To everyone who helped build this community</span>
      </p>
    </div>

    <PageToc items={tocItems} />

    <!-- Speakers Section -->
    <div class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
          <span class="lang-en">Our Speakers</span>
      <span class="lang-tr">Our Speakers</span>
        </span>
        <SectionHeading id="speakers" class="text-3xl font-semibold text-white mt-3">
          <span class="lang-en">The Voices Behind Our Events</span>
      <span class="lang-tr">The Voices Behind Our Events</span>
        </SectionHeading>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {speakers.map((speaker, i) => {
          const aff = speakerAffiliation.get(speaker.slug);
          return (
          <div class="bg-[#171717] border border-[#252525] rounded-2xl p-6 flex flex-col items-center text-center hover:border-[#444] transition-all">
            <a href={localizedPath(pagePath, `/speakers/${speaker.slug}/`)} class="group mb-4">
              {speaker.photo ? (
                <img
                  src={speaker.photo}
                  alt={speaker.name}
                  class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border border-[#252525] group-hover:border-[#444] transition-colors"
                  loading="lazy"
                />
              ) : (
                <div class={`w-32 h-32 md:w-36 md:h-36 rounded-full bg-gradient-to-br ${avatarColors[i % avatarColors.length]} flex items-center justify-center text-3xl font-bold border border-white/5 group-hover:border-white/15 transition-colors`}>
                  {speaker.initials}
                </div>
              )}
            </a>

            <a href={localizedPath(pagePath, `/speakers/${speaker.slug}/`)} class="group">
              <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-[#79c0ff] transition-colors">
                <span class="lang-en">{speaker.name}</span>
      <span class="lang-tr">{speaker.name}</span>
              </h3>
            </a>

            {(speaker.bioTr) && (
              <p class="text-[0.85rem] leading-relaxed text-[#999999] mb-3 w-full max-w-sm mx-auto">
                <span class="lang-en">{speaker.bioTr}</span>
      <span class="lang-tr">{speaker.bioTr}</span>
              </p>
            )}

            <a
              href={localizedPath(pagePath, `/speakers/${speaker.slug}/`)}
              class="inline-flex items-center gap-1.5 text-xs text-[#999999] hover:text-white transition-colors mb-3 border border-[#252525] hover:border-[#444] rounded-full px-3 py-1"
            >
              <span class="lang-en">
                {speaker.events.length} {speaker.events.length === 1 ? "event" : "events"} →
              </span>
      <span class="lang-tr">
                {speaker.events.length} {speaker.events.length === 1 ? "event" : "events"} →
              </span>
            </a>

            {aff && (
              <a
                href={localizedPath(pagePath, aff.href)}
                class="inline-flex items-center gap-2 mb-4 text-xs text-[#999999] hover:text-white transition-colors"
                title={aff.name}
              >
                <span class="rounded-md border border-[#252525] bg-[#141414] p-1">
                  <img
                    src={aff.logo}
                    alt=""
                    class="h-5 w-5 object-contain object-center"
                    width="20"
                    height="20"
                    loading="lazy"
                  />
                </span>
                <span class="lang-en">{aff.name}</span>
      <span class="lang-tr">{aff.name}</span>
              </a>
            )}

            {(speaker.twitter || speaker.linkedin || speaker.email) && (
              <div class="flex gap-4 pt-4 border-t border-[#252525] mt-auto w-full justify-center">
                {speaker.twitter && (
                  <a href={speaker.twitter} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="X / Twitter">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                )}
                {speaker.linkedin && (
                  <a href={speaker.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                )}
                {speaker.email && (
                  <a href={`mailto:${speaker.email}`} class="text-[#6E6E6E] hover:text-white transition-colors" title="Email">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </a>
                )}
              </div>
            )}
          </div>
          );
        })}
      </div>
    </div>

    <!-- Supporters Section (individuals) -->
    {supporters.length > 0 && (
      <div class="mb-24">
        <div class="text-center mb-12">
          <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
            <span class="lang-en">Our Supporters</span>
      <span class="lang-tr">Our Supporters</span>
          </span>
          <SectionHeading id="supporters" class="text-3xl font-semibold text-white mt-3">
            <span class="lang-en">The People Who Help Behind the Scenes</span>
      <span class="lang-tr">The People Who Help Behind the Scenes</span>
          </SectionHeading>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {supporters.map((supporter, i) => {
            const aff = supporterAffiliation.get(supporter.name);
            return (
            <div class="bg-[#171717] border border-[#252525] rounded-2xl p-6 flex flex-col items-center text-center hover:border-[#444] transition-all">
              {supporter.photo ? (
                <img
                  src={supporter.photo}
                  alt={supporter.name}
                  class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border border-[#252525] mb-4"
                  loading="lazy"
                />
              ) : (
                <div class={`w-32 h-32 md:w-36 md:h-36 rounded-full bg-gradient-to-br ${avatarColors[i % avatarColors.length]} flex items-center justify-center text-3xl font-bold border border-white/5 mb-4`}>
                  {supporter.initials}
                </div>
              )}

              <h3 class="text-lg font-semibold text-white mb-2">
                <span class="lang-en">{supporter.name}</span>
      <span class="lang-tr">{supporter.name}</span>
              </h3>

              <span
                class:list={[
                  "inline-flex items-center text-[0.7rem] font-semibold tracking-[0.02em] px-2 py-0.5 rounded mb-3",
                  contributorRoleBadgeClass(supporter.role),
                ]}
              >
                <span class="lang-en">{supporter.role}</span>
      <span class="lang-tr">{supporter.role}</span>
              </span>

              {aff && (
                <a
                  href={localizedPath(pagePath, aff.href)}
                  class="inline-flex items-center gap-2 mb-4 text-xs text-[#999999] hover:text-white transition-colors"
                  title={aff.name}
                >
                  <span class="rounded-md border border-[#252525] bg-[#141414] p-1">
                    <img
                      src={aff.logo}
                      alt=""
                      class="h-5 w-5 object-contain object-center"
                      width="20"
                      height="20"
                      loading="lazy"
                    />
                  </span>
                  <span class="lang-en">{aff.name}</span>
      <span class="lang-tr">{aff.name}</span>
                </a>
              )}

              <p class="text-[0.85rem] leading-relaxed text-[#999999] mb-4">
                <span class="lang-en">{supporter.contribution}</span>
      <span class="lang-tr">{supporter.contribution}</span>
              </p>

              {(supporter.twitter || supporter.linkedin || supporter.email) && (
                <div class="flex gap-4 pt-4 border-t border-[#252525] mt-auto w-full justify-center">
                  {supporter.twitter && (
                    <a href={supporter.twitter} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="X / Twitter">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                  )}
                  {supporter.linkedin && (
                    <a href={supporter.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                  )}
                  {supporter.email && (
                    <a href={`mailto:${supporter.email}`} class="text-[#6E6E6E] hover:text-white transition-colors" title="Email">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </a>
                  )}
                </div>
              )}
            </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Community Partners Section (organizations) -->
    <div>
      <div class="text-center mb-12">
        <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
          <span class="lang-en">Community Partners</span>
      <span class="lang-tr">Community Partners</span>
        </span>
        <SectionHeading id="community-partners" class="text-3xl font-semibold text-white mt-3">
          <span class="lang-en">The Organizations Behind Our Events</span>
      <span class="lang-tr">The Organizations Behind Our Events</span>
        </SectionHeading>
      </div>

      {grouped.map((group) => (
        <div class:list={["mb-10", { "opacity-70": group.role === "past-community-partner" }]}>
          <h3 class="text-[0.8rem] font-semibold uppercase tracking-[0.08em] text-[#6E6E6E] mb-4">
            <span class="lang-tr">{roleLabelTr[group.role]}</span>
            <span class="lang-en">{roleLabelEn[group.role]}</span>
          </h3>

          <div class:list={[
            "grid gap-5",
            group.role === "official" ? "grid-cols-1 max-w-[480px]" : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
          ]}>
            {group.partners.map((partner) => (
              <div
                class:list={[
                  "bg-[#171717] border border-[#252525] rounded-2xl p-6 flex flex-col gap-3 hover:border-[#444] transition-all relative",
                  { "border-white/[0.12]": group.role === "official" },
                  { "opacity-65 hover:opacity-85": group.role === "past-community-partner" },
                ]}
              >
                <div class="flex items-center gap-3.5">
                  <div
                    class:list={[
                      "flex shrink-0 items-center justify-center rounded-[10px] border border-[#252525] bg-[#141414] p-1.5",
                      group.role === "official" ? "h-14 w-14" : "h-12 w-12",
                    ]}
                  >
                    <img
                      src={partner.logo}
                      alt={partner.name}
                      class="max-h-full max-w-full object-contain object-center"
                      loading="lazy"
                    />
                  </div>
                  <div class="flex flex-col gap-1 min-w-0">
                    <a href={localizedPath(pagePath, `/partners/${partner.slug}/`)} class="text-[1.05rem] font-bold hover:text-[#79c0ff] transition-colors">
                      <span class="lang-tr">{partner.nameTr}</span>
                      <span class="lang-en">{partner.name}</span>
                    </a>
                    <span class:list={[
                      "inline-flex items-center text-[0.7rem] font-semibold uppercase tracking-[0.04em] px-2 py-0.5 rounded w-fit",
                      group.role === "official" && "text-white bg-white/[0.08] border border-white/[0.15]",
                      group.role === "community-partner" && "text-[#7dd3fc] bg-[#7dd3fc]/[0.08] border border-[#7dd3fc]/[0.15]",
                      group.role === "venue-host" && "text-[#86efac] bg-[#86efac]/[0.08] border border-[#86efac]/[0.15]",
                      group.role === "past-community-partner" && "text-[#6E6E6E] bg-white/[0.03] border border-white/[0.05]",
                    ]}>
                      <span class="lang-tr">{roleBadgeTr[group.role]}</span>
                      <span class="lang-en">{roleBadgeEn[group.role]}</span>
                    </span>
                  </div>
                </div>
                <p class="text-[0.85rem] leading-relaxed text-[#999999] line-clamp-3">
                  <span class="lang-tr">{partner.descriptionTr}</span>
                  <span class="lang-en">{partner.description}</span>
                </p>

                {partner.contributors && partner.contributors.length > 0 && (
                  <a
                    href={localizedPath(pagePath, `/partners/${partner.slug}/`)}
                    class="flex items-center gap-2.5 group"
                    title={partner.contributors.map((c) => c.name).join(", ")}
                  >
                    <span class="text-[0.7rem] text-[#6E6E6E] group-hover:text-[#999999] transition-colors shrink-0">
                      <span class="lang-en">With help from</span>
      <span class="lang-tr">With help from</span>
                    </span>
                    <div class="flex -space-x-2 rtl:space-x-reverse">
                      {partner.contributors.slice(0, 4).map((c, ci) => (
                        c.photo ? (
                          <img
                            src={c.photo}
                            alt=""
                            class="w-7 h-7 rounded-full object-cover border-2 border-[#171717] shrink-0"
                            width="28"
                            height="28"
                            loading="lazy"
                          />
                        ) : (
                          <div
                            class:list={[
                              "w-7 h-7 rounded-full bg-gradient-to-br flex items-center justify-center text-[0.6rem] font-bold border-2 border-[#171717] shrink-0",
                              avatarColors[ci % avatarColors.length],
                            ]}
                          >
                            {c.initials}
                          </div>
                        )
                      ))}
                      {partner.contributors.length > 4 && (
                        <div class="w-7 h-7 rounded-full bg-[#252525] flex items-center justify-center text-[0.6rem] font-bold text-[#999999] border border-[#171717]">
                          +{partner.contributors.length - 4}
                        </div>
                      )}
                    </div>
                  </a>
                )}

                <div
                  class:list={[
                    "flex items-center gap-2 mt-auto pt-3 border-t border-[#252525]",
                    partner.omitEventStats ? "justify-end" : "justify-between",
                  ]}
                >
                  {!partner.omitEventStats && (
                    <a
                      href={localizedPath(pagePath, `/partners/${partner.slug}/`)}
                      class="inline-flex items-center gap-1.5 text-xs text-[#999999] hover:text-white transition-colors border border-[#252525] hover:border-[#444] rounded-full px-3 py-1"
                    >
                      <span class="lang-en">
                        {partner.events.length} {partner.events.length === 1 ? "event" : "events"} →
                      </span>
      <span class="lang-tr">
                        {partner.events.length} {partner.events.length === 1 ? "event" : "events"} →
                      </span>
                    </a>
                  )}
                  <a
                    href={partner.url}
                    target="_blank"
                    rel="noreferrer"
                    class="text-[#6E6E6E] hover:text-white transition-colors"
                    title="Website"
                  >
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


---
import { config } from "@/config";
import { getSortedEvents } from "@/utils/events";

const roleOrder = ["official", "community-partner", "venue-host", "past-community-partner"] as const;

// Build speakers from event data, enriched by config (exclude ambassadors)
const events = await getSortedEvents();
const ambassadorNames = new Set(
  (config.ambassadors as readonly { name: string }[]).map((a) => a.name.toLowerCase().trim())
);
const speakerMap = new Map<string, { en: string; ar?: string }[]>();

for (const event of events) {
  const speakerNames = event.data.speakers ?? [];
  const eventTitle = { en: event.data.title, ar: event.data.titleAr };
  for (const name of speakerNames) {
    const trimmed = name.trim();
    if (!trimmed || ambassadorNames.has(trimmed.toLowerCase())) continue;
    const existing = speakerMap.get(trimmed) ?? [];
    const alreadyHas = existing.some((t) => t.en === eventTitle.en);
    if (!alreadyHas) {
      existing.push(eventTitle);
    }
    speakerMap.set(trimmed, existing);
  }
}

const configSpeakers = config.speakers as readonly { name: string; nameAr?: string; initials: string; twitter?: string; linkedin?: string; events: string[] }[];
const configByName = new Map(configSpeakers.map((s) => [s.name.toLowerCase().trim(), s]));

interface Speaker {
  name: string;
  nameAr?: string;
  initials: string;
  events: { en: string; ar?: string }[];
  twitter?: string;
  linkedin?: string;
}

function getInitials(name: string): string {
  const parts = name.trim().split(/\s+/);
  if (parts.length >= 2) {
    return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  }
  return name.slice(0, 2).toUpperCase();
}

const speakers: Speaker[] = Array.from(speakerMap.entries())
  .map(([name, events]) => {
    const key = name.toLowerCase().trim();
    const enrichment = configByName.get(key);
    return {
      name,
      nameAr: enrichment?.nameAr,
      initials: enrichment?.initials ?? getInitials(name),
      events,
      twitter: enrichment?.twitter,
      linkedin: enrichment?.linkedin,
    };
  })
  .sort((a, b) => b.events.length - a.events.length);

const roleLabelEn: Record<string, string> = {
  "official": "Official",
  "community-partner": "Community Partners",
  "venue-host": "Venue Hosts",
  "past-community-partner": "Past Partners",
};

const roleLabelAr: Record<string, string> = {
  "official": "الشريك الرسمي",
  "community-partner": "شركاء المجتمع",
  "venue-host": "مستضيفو الأماكن",
  "past-community-partner": "شركاء سابقون",
};

const roleBadgeEn: Record<string, string> = {
  "official": "Official",
  "community-partner": "Community Partner",
  "venue-host": "Venue Host",
  "past-community-partner": "Past Partner",
};

const roleBadgeAr: Record<string, string> = {
  "official": "رسمي",
  "community-partner": "شريك مجتمعي",
  "venue-host": "مستضيف",
  "past-community-partner": "شريك سابق",
};

const grouped = roleOrder
  .map((role) => ({
    role,
    partners: config.partners.filter((p) => p.role === role),
  }))
  .filter((g) => g.partners.length > 0);

const avatarColors = [
  "from-blue-500/20 to-blue-600/10 text-blue-400",
  "from-purple-500/20 to-purple-600/10 text-purple-400",
  "from-green-500/20 to-green-600/10 text-green-400",
  "from-amber-500/20 to-amber-600/10 text-amber-400",
  "from-rose-500/20 to-rose-600/10 text-rose-400",
  "from-cyan-500/20 to-cyan-600/10 text-cyan-400",
  "from-indigo-500/20 to-indigo-600/10 text-indigo-400",
];
---

<section id="thankyou" class="page-content">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">
    <!-- Hero -->
    <div class="max-w-4xl mx-auto text-center mb-20">
      <h1 class="text-4xl md:text-5xl font-semibold text-white mb-6">
        <span class="lang-en">Thank You</span>
        <span class="lang-ar">شكراً لكم</span>
      </h1>
      <p class="text-xl text-[#999999] leading-relaxed">
        <span class="lang-en">To everyone who helped build this community</span>
        <span class="lang-ar">لكل من ساهم في بناء هذا المجتمع</span>
      </p>
    </div>

    <!-- Speakers Section -->
    <div class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
          <span class="lang-en">Our Speakers</span>
          <span class="lang-ar">المتحدثون</span>
        </span>
        <h2 class="text-3xl font-semibold text-white mt-3">
          <span class="lang-en">The Voices Behind Our Events</span>
          <span class="lang-ar">الأصوات خلف فعالياتنا</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {speakers.map((speaker, i) => (
          <div class="bg-[#171717] border border-[#252525] rounded-2xl p-6 hover:border-[#444] transition-all">
            <div class="flex items-center gap-4 mb-4">
              <div class={`w-14 h-14 rounded-full bg-gradient-to-br ${avatarColors[i % avatarColors.length]} flex items-center justify-center text-lg font-bold flex-shrink-0 border border-white/5`}>
                {speaker.initials}
              </div>
              <div class="min-w-0">
                <h3 class="text-lg font-semibold text-white truncate">
                  <span class="lang-en">{speaker.name}</span>
                  <span class="lang-ar">{speaker.nameAr ?? speaker.name}</span>
                </h3>
                <div class="text-xs text-[#999999]">
                  <span class="lang-en">{speaker.events.length} {speaker.events.length === 1 ? "event" : "events"}</span>
                  <span class="lang-ar">{speaker.events.length} فعاليات</span>
                </div>
              </div>
            </div>

            <div class="flex flex-wrap gap-1.5 mb-4">
              {speaker.events.map((ev) => (
                <span class="text-[11px] text-[#8A8A8A] bg-white/5 border border-white/5 px-2 py-0.5 rounded-md">
                  <span class="lang-en">{ev.en}</span>
                  <span class="lang-ar">{ev.ar ?? ev.en}</span>
                </span>
              ))}
            </div>

            {(speaker.twitter || speaker.linkedin) && (
              <div class="flex gap-3 pt-3 border-t border-[#252525]">
                {speaker.twitter && (
                  <a href={speaker.twitter} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="X / Twitter">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                )}
                {speaker.linkedin && (
                  <a href={speaker.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Supporters Section -->
    <div>
      <div class="text-center mb-12">
        <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
          <span class="lang-en">Our Supporters</span>
          <span class="lang-ar">الداعمون</span>
        </span>
        <h2 class="text-3xl font-semibold text-white mt-3">
          <span class="lang-en">Organizations That Made It All Possible</span>
          <span class="lang-ar">المؤسسات التي جعلت كل هذا ممكناً</span>
        </h2>
      </div>

      {grouped.map((group) => (
        <div class:list={["mb-10", { "opacity-70": group.role === "past-community-partner" }]}>
          <h3 class="text-[0.8rem] font-semibold uppercase tracking-[0.08em] text-[#6E6E6E] mb-4">
            <span class="lang-ar">{roleLabelAr[group.role]}</span>
            <span class="lang-en">{roleLabelEn[group.role]}</span>
          </h3>

          <div class:list={[
            "grid gap-5",
            group.role === "official" ? "grid-cols-1 max-w-[480px]" : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3",
          ]}>
            {group.partners.map((partner) => (
              <a
                href={partner.url}
                target="_blank"
                rel="noreferrer"
                class:list={[
                  "bg-[#171717] border border-[#252525] rounded-2xl p-6 flex flex-col gap-3 hover:border-[#444] transition-all relative",
                  { "border-white/[0.12]": group.role === "official" },
                  { "opacity-65 hover:opacity-85": group.role === "past-community-partner" },
                ]}
              >
                <div class="flex items-center gap-3.5">
                  <img
                    src={partner.logo}
                    alt={partner.name}
                    class:list={[
                      "rounded-[10px] object-cover flex-shrink-0",
                      group.role === "official" ? "w-14 h-14" : "w-12 h-12",
                    ]}
                    loading="lazy"
                  />
                  <div class="flex flex-col gap-1 min-w-0">
                    <span class="text-[1.05rem] font-bold">
                      <span class="lang-ar">{partner.nameAr}</span>
                      <span class="lang-en">{partner.name}</span>
                    </span>
                    <span class:list={[
                      "inline-flex items-center text-[0.7rem] font-semibold uppercase tracking-[0.04em] px-2 py-0.5 rounded w-fit",
                      group.role === "official" && "text-white bg-white/[0.08] border border-white/[0.15]",
                      group.role === "community-partner" && "text-[#7dd3fc] bg-[#7dd3fc]/[0.08] border border-[#7dd3fc]/[0.15]",
                      group.role === "venue-host" && "text-[#86efac] bg-[#86efac]/[0.08] border border-[#86efac]/[0.15]",
                      group.role === "past-community-partner" && "text-[#6E6E6E] bg-white/[0.03] border border-white/[0.05]",
                    ]}>
                      <span class="lang-ar">{roleBadgeAr[group.role]}</span>
                      <span class="lang-en">{roleBadgeEn[group.role]}</span>
                    </span>
                  </div>
                </div>
                <p class="text-[0.85rem] leading-relaxed text-[#999999] line-clamp-3">
                  <span class="lang-ar">{partner.descriptionAr}</span>
                  <span class="lang-en">{partner.description}</span>
                </p>
                {partner.cities.length > 0 && (
                  <span class="text-xs text-[#6E6E6E]">
                    {partner.cities.join(", ")}
                  </span>
                )}
                <svg class="absolute top-6 end-6 text-[#6E6E6E] group-hover:text-white transition-colors" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

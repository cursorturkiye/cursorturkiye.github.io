---
import type { BlogPost } from "@/utils/blog";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const dateStr = post.date.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const dateStrAr = post.date.toLocaleDateString("ar-SA", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const eventTypeLabels: Record<string, { en: string; ar: string }> = {
  meetup: { en: "Meetup", ar: "لقاء" },
  hackathon: { en: "Hackathon", ar: "هاكاثون" },
  workshop: { en: "Workshop", ar: "ورشة عمل" },
  build: { en: "Build", ar: "بناء" },
};
---

<a href={`/blog/${post.slug}`} class="blog-card group block bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden card-hover">
  {post.coverImage ? (
    <div class="aspect-[16/10] overflow-hidden">
      <img
        src={post.coverImage}
        alt={post.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-[16/10] bg-gradient-to-br from-[#1a1a1a] to-[#0d0d0d] flex items-center justify-center border-b border-[#252525]">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[#333] group-hover:text-[#444] transition-colors" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <line x1="3" y1="9" x2="21" y2="9"/>
        <line x1="9" y1="21" x2="9" y2="9"/>
      </svg>
    </div>
  )}

  <div class="p-5 flex flex-col gap-3">
    <!-- Badge -->
    <div class="flex items-center gap-2">
      {post.source === "event" ? (
        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20">
          <span class="lang-en">Event Recap</span>
          <span class="lang-ar">ملخص فعالية</span>
        </span>
      ) : (
        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
          <span class="lang-en">Article</span>
          <span class="lang-ar">مقال</span>
        </span>
      )}
      {post.eventType && (
        <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-white/5 text-[#999] border border-[#252525] capitalize">
          <span class="lang-en">{eventTypeLabels[post.eventType]?.en ?? post.eventType}</span>
          <span class="lang-ar">{eventTypeLabels[post.eventType]?.ar ?? post.eventType}</span>
        </span>
      )}
    </div>

    <!-- Title -->
    <h3 class="text-lg font-semibold text-white leading-snug">
      <span class="lang-ar">{post.titleAr ?? post.title}</span>
      <span class="lang-en">{post.title}</span>
    </h3>

    <!-- Meta -->
    <div class="flex items-center gap-2 text-xs text-[#6E6E6E]">
      <time>
        <span class="lang-en">{dateStr}</span>
        <span class="lang-ar">{dateStrAr}</span>
      </time>
      {post.author && (
        <>
          <span>·</span>
          <span>{post.author}</span>
        </>
      )}
    </div>

    <!-- Description -->
    <p class="text-sm text-[#999] leading-relaxed line-clamp-2">
      <span class="lang-ar">{post.descriptionAr ?? post.description}</span>
      <span class="lang-en">{post.description}</span>
    </p>

    <!-- Read more -->
    <span class="text-sm font-medium text-white/60 group-hover:text-white transition-colors mt-auto">
      <span class="lang-en">Read more &rarr;</span>
      <span class="lang-ar">اقرأ المزيد &larr;</span>
    </span>
  </div>
</a>

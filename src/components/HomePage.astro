---
import { config } from "@/config";
import { getUpcomingEvents, getPastEvents, getSortedEvents, isHostedCommunityEventType } from "@/utils/events";
import type { CollectionEntry } from "astro:content";
import PageToc from "@/components/PageToc.astro";
import { localizedPath } from "@/utils/i18n-path";

const pagePath = Astro.url.pathname;

type EventEntry = CollectionEntry<"events">;

const allUpcoming = (await getUpcomingEvents()).filter((e: EventEntry) => isHostedCommunityEventType(e.data.type));
const upcoming = allUpcoming.filter((e: EventEntry) => e.data.status !== "backlog");
const past = (await getPastEvents()).filter((e: EventEntry) => isHostedCommunityEventType(e.data.type));
const allEvents = (await getSortedEvents()).filter((e: EventEntry) => isHostedCommunityEventType(e.data.type));
const nextEvent = upcoming[0];
const citiesCount = new Set(allEvents.map((e: EventEntry) => e.data.location)).size;

function formatShortDate(date: Date): { en: string; tr: string } {
  return {
    en: date.toLocaleDateString("en-US", { month: "short", day: "numeric" }),
    tr: date.toLocaleDateString("tr-TR", { month: "short", day: "numeric" }),
  };
}

const homeTocItems = [
  { id: "stats", labelEn: "Stats", labelTr: "istatistikler" },
  { id: "featured", labelEn: "Featured", labelTr: "Öne Çıkanlar" },
  { id: "partners", labelEn: "Partners", labelTr: "Ortaklıklar" },
  { id: "external-collabs", labelEn: "External", labelTr: "Harici" },
];

interface ExternalCollabHost {
  name: string;
  nameTr: string;
  url: string;
  logo: string;
}

/** Unique external hosts from invites, excluding orgs that are already partners. */
const externalCollabHosts: ExternalCollabHost[] = (() => {
  const seen = new Set<string>();
  const out: ExternalCollabHost[] = [];
  for (const inv of config.invites) {
    if (!("invitedByLogo" in inv) || !inv.invitedByLogo) continue;
    if (seen.has(inv.invitedByUrl)) continue;
    seen.add(inv.invitedByUrl);
    const isPartnerOrg = config.partners.some(
      (p) => inv.invitedByLogo === p.logo
    );
    if (isPartnerOrg) continue;
    out.push({
      name: inv.invitedBy,
      nameTr: inv.invitedByTr,
      url: inv.invitedByUrl,
      logo: inv.invitedByLogo,
    });
  }
  return out;
})();
---

<section id="home">
  <div class="max-w-7xl mx-auto px-6 md:px-10 relative">
    <div class="glow-bg opacity-40 top-0"></div>

    <!-- Hero: title left, map right -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center pt-24 md:pt-32 pb-16 relative z-10">
      <!-- Left: text content -->
      <div class="flex flex-col items-start text-start">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm mb-8 transition-transform hover:scale-105 cursor-default">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)] animate-pulse-slow"></span>
          <span class="text-xs text-[#8A8A8A] font-medium tracking-wide">
            <span class="lang-tr">Türkiye'deki aktif yazılım geliştirici topluluğu</span>
            <span class="lang-en">Active developer community in Türkiye</span>
          </span>
        </div>

        <h1 class="text-5xl md:text-7xl font-semibold tracking-tighter mb-6 leading-[1.1] text-white">
          <span class="lang-en">The AI-Native<br><span class="text-[#8A8A8A]">Turkish Community.</span></span>
          <span class="lang-tr">Yapay Zeka<br><span class="text-[#8A8A8A]">Türk Topluluğu.</span></span>
        </h1>

        <p class="text-lg text-[#8A8A8A] leading-relaxed mb-8 max-w-lg">
          <span class="lang-en">Hands-on technical events focused on shipping faster with AI-native developer tools. Built by the community, for the community.</span>
          <span class="lang-tr">Yapay zekâ tabanlı geliştirici araçlarıyla daha hızlı ürün geliştirmeye odaklanan uygulamalı teknik etkinlikler. Topluluk tarafından, topluluk için geliştirildi.</span>
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4 w-full sm:w-auto">
          <a href={config.social.discord} target="_blank" rel="noreferrer" class="w-full sm:w-auto btn-primary px-8 py-3.5 rounded-full font-medium text-sm flex items-center justify-center gap-2">

---
import {
  getUpcomingEvents,
  getPastEvents,
  getEventThumbnailUrl,
  getEventAlbumPreviewUrls,
  isHostedCommunityEventType,
} from "@/utils/events";
import { getEventIdsWithBlog, eventBlogSlug } from "@/utils/blog";
import { getSpeakerNameMap, getAffiliationPartnerDisplay, getEventPartnersMap, getEventPartners, partnerRoleLabels } from "@/utils/people";
import type { EventPartnerEntry } from "@/utils/people";
import { config } from "@/config";
import type { CollectionEntry } from "astro:content";
import PageToc from "@/components/PageToc.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { localizedPath } from "@/utils/i18n-path";

const pagePath = Astro.url.pathname;
const speakerMap = getSpeakerNameMap();
const partnersMap = getEventPartnersMap();
const siteOrigin = Astro.site?.origin ?? "https://cursorturkiye.com";

function xShareLink(url: string, text: string): string {
  return `https://x.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(text)}`;
}

function linkedInShareLink(url: string): string {
  return `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
}

/** Plain text + URL for apps that prefill a message (e.g. WhatsApp). */
function whatsappShareLink(url: string, text: string): string {
  return `https://api.whatsapp.com/send?text=${encodeURIComponent(`${text}\n${url}`)}`;
}

/** Absolute URL for a site path, respecting current `/ar` or `/en` prefix. */
function absoluteSitePath(path: string): string {
  return new URL(localizedPath(pagePath, path), siteOrigin).href;
}

type EventEntry = CollectionEntry<"events">;

const allUpcoming = (await getUpcomingEvents()).filter((e: EventEntry) => isHostedCommunityEventType(e.data.type));
const upcoming = allUpcoming.filter((e: EventEntry) => e.data.status !== "backlog");
const backlog = allUpcoming.filter((e: EventEntry) => e.data.status === "backlog");
const past = (await getPastEvents()).filter((e: EventEntry) => isHostedCommunityEventType(e.data.type));
const blogEventIds = await getEventIdsWithBlog();
const invites = [...config.invites].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const backlogSorted = [...backlog].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

/** Shown when an event has no `coverPhoto` / photo assets for the card strip. */
const eventCardPlaceholder = "/placeholders/event-card.svg";

const tocItems = [
  ...(backlog.length > 0 ? [{ id: "planned-dates", labelEn: "Planned dates", labelTr: "Planlanan Tarihler" }] : []),
  { id: "upcoming", labelEn: "Upcoming", labelTr: "Yaklaşan Etkinlikler" },
  { id: "past", labelEn: "Past", labelTr: "Geçmiş Etkinlikler" },
  ...(invites.length > 0 ? [{ id: "external-invitations", labelEn: "External", labelTr: "Dış Davetler" }] : []),
];

function formatMonth(date: Date) {
  return date.toLocaleDateString("en-US", { month: "short" });
}

function formatMonthTr(date: Date) {
  return date.toLocaleDateString("tr-TR", { month: "short" });
}

function formatDay(date: Date) {
  return date.getDate().toString().padStart(2, "0");
}

function formatDayTr(date: Date) {
  return date.getDate().toLocaleString("tr-TR");
}

/** Calendar day for invite `YYYY-MM-DD` strings (no UTC day-shift). */
function formatInviteFullDate(isoDate: string): { en: string; tr: string } {
  const d = new Date(`${isoDate}T12:00:00`);
  return {
    en: d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }),
    tr: d.toLocaleDateString("tr-TR", { month: "short", day: "numeric", year: "numeric" }),
  };
}

/** "Invited by" href: locale-prefixed for site paths, unchanged for external URLs. */
function inviteInviterHref(url: string): string {
  if (!url.startsWith("/")) return url;
  const path = url === "/" ? "/" : url.endsWith("/") ? url : `${url}/`;
  return localizedPath(pagePath, path);
}

function isSameSiteInviteUrl(url: string): boolean {
  return url.startsWith("/");
}

function typeLabel(type: string): { en: string; tr: string } {
  const labels: Record<string, { en: string; tr: string }> = {
    meetup: { en: "Meetup", tr: "Buluşma" },
    hackathon: { en: "Hackathon", tr: "Hackathon" },
    workshop: { en: "Workshop", tr: "Atölye" },
    build: { en: "Build", tr: "Build Oturumu" },
    talk: { en: "Talk", tr: "Konuşma" },
    interview: { en: "Interview", tr: "Röportaj" },
  };
  return labels[type] ?? { en: type, tr: type };
}
---

<section id="events">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">
    <div class="mb-16 border-b border-[#252525] pb-8">
      <h1 class="text-4xl md:text-5xl font-semibold text-white mb-4">
        <span class="lang-en">Events</span>
        <span class="lang-tr">Etkinlikler</span>
      </h1>
      <p class="text-[#999999] text-lg w-full max-w-none">
        <span class="lang-en">
          Meetups, hackathons, workshops, and build sessions we host—focused on AI-native development with Cursor. Invited talks and
          interviews are not listed here. Past hosted events may include recaps you can open like blog posts.
        </span>
      <span class="lang-tr">
          Cursor ile AI-native geliştirmeye odaklanan buluşma, hackathon, atölye ve build oturumlarını burada listeliyoruz.
          Dış davetli konuşma ve röportajlar bu bölümde yer almaz. Geçmiş etkinliklerin bazılarında blog formatında etkinlik özetleri bulunur.
        </span>
      </p>
    </div>

    <PageToc items={tocItems} />

    <div id="events-sections">
      {backlog.length > 0 && (
        <div class="mb-14">
          <SectionHeading id="planned-dates" class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-4">
            <span class="lang-en">Planned dates</span>
      <span class="lang-tr">Planlanan tarihler</span>
          </SectionHeading>
          <div class="border border-dashed border-[#252525] rounded-2xl p-6">
            <p class="text-sm text-[#6E6E6E] mb-4">
              <span class="lang-en">Tentative slots — details and registration will be announced later.</span>
      <span class="lang-tr">Geçici takvimler — detaylar ve kayıt bilgisi daha sonra duyurulacaktır.</span>
            </p>
            <div class="flex flex-wrap gap-3">
              {backlogSorted.map((event: EventEntry) => {
                const mEn = event.data.date.toLocaleDateString("en-US", { month: "short" });
                const dEn = event.data.date.getDate();
                const mTr = event.data.date.toLocaleDateString("tr-TR", { month: "short" });
                const dTr = event.data.date.getDate().toLocaleString("tr-TR");
                return (
                  <div class="bg-[#1F1F1F] rounded-lg px-4 py-2.5 border border-[#252525] text-center min-w-[72px] max-w-[140px]">
                    <div class="text-[10px] text-[#6E6E6E] uppercase font-bold">
                      <span class="lang-en">{mEn}</span>
      <span class="lang-tr">{mTr}</span>
                    </div>
                    <div class="text-lg font-bold text-[#6E6E6E] leading-tight">
                      <span class="lang-en">{dEn}</span>
      <span class="lang-tr">{dTr}</span>
                    </div>
                    <div class="text-[10px] text-[#8b949e] mt-1.5 leading-snug border-t border-[#252525]/80 pt-1.5">
                      <span class="lang-en">{event.data.location}</span>
      <span class="lang-tr">{event.data.location}</span>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      <div class="mb-14">
        <SectionHeading id="upcoming" class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-4">
          <span class="lang-en">Upcoming</span>
      <span class="lang-tr">Yaklaşan</span>
        </SectionHeading>
        <div class="grid md:grid-cols-3 gap-6">
          {upcoming.map((event: EventEntry) => {
            const thumbUrl = getEventThumbnailUrl(event);
            const albumUrls = getEventAlbumPreviewUrls(event, 4);
            const showAlbumGrid = albumUrls.length >= 2;
            return (
            <div class="event-card bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden hover:border-white/20 transition-all group flex flex-col h-full">
              <div class="relative aspect-[16/10] w-full shrink-0 bg-[#0d1117] border-b border-[#252525]">
                {showAlbumGrid ? (
                  <div
                    class:list={[
                      "grid h-full w-full gap-0.5",
                      albumUrls.length === 2 ? "grid-cols-2" : "grid-cols-2 grid-rows-2",
                    ]}
                  >
                    {albumUrls.map((url: string, i: number) => (
                      <div
                        class:list={[
                          "relative min-h-0 overflow-hidden",
                          albumUrls.length === 3 && i === 2 ? "col-span-2" : "",
                        ]}
                      >
                        <img
                          src={url}
                          alt={i === 0 ? event.data.title : ""}
                          class="absolute inset-0 w-full h-full object-cover"
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    ))}
                  </div>
                ) : (
                  <img
                    src={thumbUrl ?? eventCardPlaceholder}
                    alt={thumbUrl ? event.data.title : ""}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow min-h-0">
              <div class="flex justify-between items-start mb-6">
                <div class="bg-[#1F1F1F] rounded-lg px-3 py-1 border border-[#252525] text-center min-w-[60px]">
                  <div class="text-[10px] text-[#999999] uppercase font-bold">
                    <span class="lang-en">{formatMonth(event.data.date)}</span>
      <span class="lang-tr">{formatMonthTr(event.data.date)}</span>
                  </div>
                  <div class="text-xl font-bold text-white">
                    <span class="lang-en">{formatDay(event.data.date)}</span>
      <span class="lang-tr">{formatDayTr(event.data.date)}</span>
                  </div>
                </div>
                <span class="px-2 py-1 rounded-full bg-white/5 text-[10px] font-medium tracking-wide uppercase text-[#999999] border border-white/5">
                  <span class="lang-en">{typeLabel(event.data.type).en}</span>
      <span class="lang-tr">{typeLabel(event.data.type).tr}</span>
                </span>
              </div>
              <h3 class="text-xl font-semibold text-white mb-2 group-hover:text-white transition-colors">
                <span class="lang-en">{event.data.title}</span>
      <span class="lang-tr">{event.data.title}</span>
              </h3>
              {event.data.speakers && event.data.speakers.length > 0 && (
                <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs text-[#6E6E6E] mb-3">
                  {event.data.speakers.map((name: string) => {
                    const info = speakerMap.get(name.toLowerCase().trim());
                    const displayNameEn = info?.name ?? name;
                    const displayNameTr = info?.nameTr ?? displayNameEn;
                    const partner = info?.affiliationPartnerSlug ? getAffiliationPartnerDisplay(info.affiliationPartnerSlug) : undefined;
                    const SpeakerTag = info ? "a" : "span";
                    return (
                      <SpeakerTag {...(info ? { href: localizedPath(pagePath, `/speakers/${info.slug}/`) } : {})} class={`flex items-center gap-1.5 ${info ? "hover:text-white cursor-pointer" : ""} transition-colors group/speaker`}>
                        {info?.photo ? (
                          <img src={info.photo} alt="" class="w-5 h-5 rounded-full object-cover shrink-0 border border-[#252525]" width="20" height="20" loading="lazy" />
                        ) : (
                          <span class="w-5 h-5 rounded-full bg-[#252525] border border-[#333] shrink-0 flex items-center justify-center text-[7px] font-bold text-[#8A8A8A]">{info?.initials ?? name.slice(0, 2).toUpperCase()}</span>
                        )}
                        <span class={`${info ? "group-hover/speaker:text-white" : ""} transition-colors`}>
                          <span class="lang-en">{displayNameEn}</span>
      <span class="lang-tr">{displayNameTr}</span>
                        </span>
                        {partner && (
                          <img src={partner.logo} alt={partner.name} class="w-3.5 h-3.5 object-contain opacity-50 shrink-0" width="14" height="14" loading="lazy" />
                        )}
                      </SpeakerTag>
                    );
                  })}
                </div>
              )}
              <p class="text-sm text-[#999999] mb-6 flex-grow">
                <span class="lang-en">{event.data.description}</span>
      <span class="lang-tr">{event.data.description}</span>
              </p>
              {(() => {
                const partners = getEventPartners(event.id, event.data.venue, partnersMap);
                return partners.length > 0 && (
                  <div class="flex flex-wrap items-center gap-3 mb-3">
                    {partners.map((p: EventPartnerEntry) => (
                      <a href={localizedPath(pagePath, `/partners/${p.slug}/`)} class="flex items-center gap-1.5 rounded-full bg-white/5 border border-[#252525] px-2.5 py-1 hover:border-[#444] transition-colors">
                        <img src={p.logo} alt={p.name} class="w-5 h-5 object-contain" width="20" height="20" loading="lazy" />
                        <span class="text-[10px] text-[#8b949e] leading-tight">
                          <span class="lang-en">{partnerRoleLabels[p.role].en}</span>
      <span class="lang-tr">{partnerRoleLabels[p.role].tr}</span>
                        </span>
                      </a>
                    ))}
                  </div>
                );
              })()}
              <div class="flex items-center justify-between pt-4 border-t border-[#252525] mt-auto">
                <div class="flex items-center gap-2 text-xs text-[#999999]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="lang-en">{event.data.location}{event.data.venue && <span class="text-[#6E6E6E]"> · {event.data.venue}</span>}</span>
                  <span class="lang-tr">{event.data.locationTr}{event.data.venue && <span class="text-[#6E6E6E]"> · {event.data.venue}</span>}</span>
                </div>
                {(() => {
                  const shareUrl = event.data.lumaUrl ?? absoluteSitePath("/events");
                  const shareText = `${event.data.title} — Cursor Türkiye`;
                  return (
                    <div class="flex flex-col items-end gap-1 shrink-0" role="group" aria-label="Share with others">
                      <p class="text-[10px] leading-tight text-[#6E6E6E] text-end max-w-[9rem] sm:max-w-none">
                        <span class="lang-en">Share with others</span>
      <span class="lang-tr">Paylaş</span>
                      </p>
                      <div class="flex items-center gap-1">
                        <a href={xShareLink(shareUrl, shareText)} target="_blank" rel="noreferrer" class="w-7 h-7 flex items-center justify-center rounded-full text-[#6E6E6E] hover:text-white transition-colors" aria-label="Share on X">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                        <a href={linkedInShareLink(shareUrl)} target="_blank" rel="noreferrer" class="w-7 h-7 flex items-center justify-center rounded-full text-[#6E6E6E] hover:text-white transition-colors" aria-label="Share on LinkedIn">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                        </a>
                        <a href={whatsappShareLink(shareUrl, shareText)} target="_blank" rel="noreferrer" class="w-7 h-7 flex items-center justify-center rounded-full text-[#6E6E6E] hover:text-[#25D366] transition-colors" aria-label="Share on WhatsApp">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                        </a>
                      </div>
                    </div>
                  );
                })()}
              </div>
              </div>
            </div>
            );
          })}
          {upcoming.length === 0 && (
            <div class="col-span-full py-12 text-center">
              <p class="text-[#999999] text-lg">
                {backlog.length > 0 ? (
                  <>
                    <span class="lang-en">No confirmed upcoming events with full details yet — see planned dates above.</span>
      <span class="lang-tr">Detayları netleşmiş yaklaşan etkinlik henüz yok — yukarıdaki planlanan tarihlere göz atabilirsiniz.</span>
                  </>
                ) : (
                  <>
                    <span class="lang-en">No upcoming events listed yet.</span>
      <span class="lang-tr">Henüz yaklaşan etkinlik listelenmedi.</span>
                  </>
                )}
              </p>
            </div>
          )}
        </div>
      </div>

      <div>
        <SectionHeading id="past" class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-2">
          <span class="lang-en">Past</span>
      <span class="lang-tr">Geçmiş</span>
        </SectionHeading>
        <p class="text-sm text-[#6E6E6E] mb-6 max-w-2xl">
          <span class="lang-en">Each recap is a full post with photos, takeaways, and links. Open “Read recap” to view it.</span>
      <span class="lang-tr">Her özet; fotoğraflar, çıkarımlar ve bağlantılar içeren tam bir yazıdır. Görmek için “Etkinlik özetini oku” butonunu kullanın.</span>
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          {past.map((event: EventEntry) => {
            const hasRecap = blogEventIds.has(event.id);
            const thumbUrl = getEventThumbnailUrl(event);
            const albumUrls = getEventAlbumPreviewUrls(event, 4);
            const showAlbumGrid = albumUrls.length >= 2;
            const recapHref = localizedPath(pagePath, `/blog/${eventBlogSlug(event.id)}/`);
            return (
              <div class="event-card bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden hover:border-white/20 transition-all group flex flex-col h-full">
                <div class="relative aspect-[16/10] w-full shrink-0 bg-[#0d1117] border-b border-[#252525]">
                  {hasRecap && (
                    <a
                      href={recapHref}
                      class="absolute inset-0 z-10 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[#58a6ff]/60"
                      aria-label="Etkinlik özetinin tamamını oku"
                      title="Etkinlik özetinin tamamını oku"
                    />
                  )}
                  {showAlbumGrid ? (
                    <div
                      class:list={[
                        "grid h-full w-full gap-0.5",
                        albumUrls.length === 2 ? "grid-cols-2" : "grid-cols-2 grid-rows-2",
                      ]}
                    >
                      {albumUrls.map((url: string, i: number) => (
                        <div
                          class:list={[
                            "relative min-h-0 overflow-hidden",
                            albumUrls.length === 3 && i === 2 ? "col-span-2" : "",
                          ]}
                        >
                          <img
                            src={url}
                            alt={i === 0 ? event.data.title : ""}
                            class="absolute inset-0 w-full h-full object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                      ))}
                    </div>
                  ) : (
                    <img
                      src={thumbUrl ?? eventCardPlaceholder}
                      alt={thumbUrl ? event.data.title : ""}
                      class="absolute inset-0 w-full h-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </div>
                <div class="p-6 flex flex-col flex-grow min-h-0">
                <div class="flex justify-between items-start mb-6">
                  <div class="bg-[#1F1F1F] rounded-lg px-3 py-1 border border-[#252525] text-center min-w-[60px] opacity-50">
                    <div class="text-[10px] text-[#999999] uppercase font-bold">
                      <span class="lang-en">{formatMonth(event.data.date)}</span>
      <span class="lang-tr">{formatMonthTr(event.data.date)}</span>
                    </div>
                    <div class="text-xl font-bold text-white">
                      <span class="lang-en">{formatDay(event.data.date)}</span>
      <span class="lang-tr">{formatDayTr(event.data.date)}</span>
                    </div>
                  </div>
                  <span class="px-2 py-1 rounded-full bg-white/5 text-[10px] font-medium tracking-wide uppercase text-[#999999] border border-white/5">
                    <span class="lang-en">{typeLabel(event.data.type).en}</span>
      <span class="lang-tr">{typeLabel(event.data.type).tr}</span>
                  </span>
                </div>
                <h3 class="text-xl font-semibold mb-2 leading-snug">
                  {hasRecap ? (
                    <a
                      href={recapHref}
                      class="text-white hover:text-[#79c0ff] transition-colors outline-none focus-visible:ring-2 focus-visible:ring-[#58a6ff]/60 focus-visible:ring-offset-2 focus-visible:ring-offset-[#171717] rounded-sm"
                    >
                      <span class="lang-en">{event.data.title}</span>
      <span class="lang-tr">{event.data.title}</span>
                    </a>
                  ) : (
                    <>
                      <span class="lang-en text-[#999999]">{event.data.title}</span>
                      <span class="lang-tr text-[#999999]">{event.data.titleTr}</span>
                    </>
                  )}
                </h3>
                {event.data.speakers && event.data.speakers.length > 0 && (
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs text-[#6E6E6E] mb-3">
                    {event.data.speakers.map((name: string) => {
                      const info = speakerMap.get(name.toLowerCase().trim());
                      const displayNameEn = info?.name ?? name;
                      const displayNameTr = info?.nameTr ?? displayNameEn;
                      const partner = info?.affiliationPartnerSlug ? getAffiliationPartnerDisplay(info.affiliationPartnerSlug) : undefined;
                      const SpeakerTag = info ? "a" : "span";
                      return (
                        <SpeakerTag {...(info ? { href: localizedPath(pagePath, `/speakers/${info.slug}/`) } : {})} class={`flex items-center gap-1.5 ${info ? "hover:text-white cursor-pointer" : ""} transition-colors group/speaker`}>
                          {info?.photo ? (
                            <img src={info.photo} alt="" class="w-5 h-5 rounded-full object-cover shrink-0 border border-[#252525]" width="20" height="20" loading="lazy" />
                          ) : (
                            <span class="w-5 h-5 rounded-full bg-[#252525] border border-[#333] shrink-0 flex items-center justify-center text-[7px] font-bold text-[#8A8A8A]">{info?.initials ?? name.slice(0, 2).toUpperCase()}</span>
                          )}
                          <span class={`${info ? "group-hover/speaker:text-white" : ""} transition-colors`}>
                            <span class="lang-en">{displayNameEn}</span>
      <span class="lang-tr">{displayNameTr}</span>
                          </span>
                          {partner && (
                            <img src={partner.logo} alt={partner.name} class="w-3.5 h-3.5 object-contain opacity-50 shrink-0" width="14" height="14" loading="lazy" />
                          )}
                        </SpeakerTag>
                      );
                    })}
                  </div>
                )}
                <p class="text-sm text-[#999999] mb-6 flex-grow">
                  <span class="lang-en">{event.data.description}</span>
      <span class="lang-tr">{event.data.description}</span>
                </p>
                {(() => {
                  const partners = getEventPartners(event.id, event.data.venue, partnersMap);
                  return partners.length > 0 && (
                    <div class="flex flex-wrap items-center gap-3 mb-3">
                      {partners.map((p: EventPartnerEntry) => (
                        <a href={localizedPath(pagePath, `/partners/${p.slug}/`)} class="flex items-center gap-1.5 rounded-full bg-white/5 border border-[#252525] px-2.5 py-1 hover:border-[#444] transition-colors">
                          <img src={p.logo} alt={p.name} class="w-5 h-5 object-contain" width="20" height="20" loading="lazy" />
                          <span class="text-[10px] text-[#8b949e] leading-tight">
                            <span class="lang-en">{partnerRoleLabels[p.role].en}</span>
      <span class="lang-tr">{partnerRoleLabels[p.role].tr}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  );
                })()}
                <div class="mt-auto flex flex-col gap-3 pt-4 border-t border-[#252525]">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2 text-xs text-[#999999]">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      <span class="lang-en">{event.data.location}{event.data.venue && <span class="text-[#6E6E6E]"> · {event.data.venue}</span>}</span>
                      <span class="lang-tr">{event.data.locationTr}{event.data.venue && <span class="text-[#6E6E6E]"> · {event.data.venue}</span>}</span>
                    </div>
                    {(() => {
                      const shareUrl = hasRecap ? absoluteSitePath(recapHref) : absoluteSitePath("/events");
                      const shareText = `${event.data.title} — Cursor Türkiye`;
                      return (
                        <div class="flex flex-col items-end gap-1 shrink-0" role="group" aria-label="Share with others">
                          <p class="text-[10px] leading-tight text-[#6E6E6E] text-end max-w-[9rem] sm:max-w-none">
                            <span class="lang-en">Share with others</span>
      <span class="lang-tr">Paylaş</span>
                          </p>
                          <div class="flex items-center gap-1">
                            <a href={xShareLink(shareUrl, shareText)} target="_blank" rel="noreferrer" class="w-7 h-7 flex items-center justify-center rounded-full text-[#6E6E6E] hover:text-white transition-colors" aria-label="Share on X">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                            </a>
                            <a href={linkedInShareLink(shareUrl)} target="_blank" rel="noreferrer" class="w-7 h-7 flex items-center justify-center rounded-full text-[#6E6E6E] hover:text-white transition-colors" aria-label="Share on LinkedIn">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                            </a>
                            <a href={whatsappShareLink(shareUrl, shareText)} target="_blank" rel="noreferrer" class="w-7 h-7 flex items-center justify-center rounded-full text-[#6E6E6E] hover:text-[#25D366] transition-colors" aria-label="Share on WhatsApp">
                              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                            </a>
                          </div>
                        </div>
                      );
                    })()}
                  </div>
                  {hasRecap ? (
                    <a
                      href={recapHref}
                      class="w-full group/recap text-center py-3 px-4 rounded-xl text-sm font-semibold inline-flex items-center justify-center gap-2.5
                        border border-[#58a6ff]/40 bg-[#58a6ff]/[0.08] text-[#c9e1ff] hover:bg-[#58a6ff]/18 hover:border-[#58a6ff]/70 hover:text-white
                        transition-all shadow-[inset_0_1px_0_rgba(255,255,255,0.06)]"
                    >
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-[#58a6ff] shrink-0 group-hover/recap:text-[#79c0ff] transition-colors" aria-hidden="true">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        <path d="M8 7h8M8 11h6"/>
                      </svg>
                      <span class="lang-en">Read full recap</span>
      <span class="lang-tr">Etkinlik özetini oku</span>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#58a6ff] shrink-0 opacity-80 group-hover/recap:opacity-100 rtl:rotate-180 transition-opacity" aria-hidden="true">
                        <path d="M5 12h14M13 6l6 6-6 6"/>
                      </svg>
                    </a>
                  ) : (
                    <p class="text-xs text-[#5c5c5c]">
                      <span class="lang-en">Written recap not published yet.</span>
      <span class="lang-tr">Yazılı etkinlik özeti henüz yayımlanmadı.</span>
                    </p>
                  )}
                </div>
                </div>
              </div>
            );
          })}
          {past.length === 0 && (
            <div class="col-span-full py-12 text-center">
              <p class="text-[#999999] text-lg">
                <span class="lang-en">No past events to show yet.</span>
      <span class="lang-tr">Gösterilecek geçmiş etkinlik henüz yok.</span>
              </p>
            </div>
          )}
        </div>
      </div>

      {invites.length > 0 && (
        <div class="mt-14">
          <SectionHeading id="external-invitations" class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-2">
            <span class="lang-en">External Invitations</span>
      <span class="lang-tr">Dış davetler</span>
          </SectionHeading>
          <p class="text-sm text-[#6E6E6E] mb-6 max-w-2xl">
            <span class="lang-en">Talks and interviews our community members were invited to by external organizations — not hosted by Cursor Türkiye.</span>
      <span class="lang-tr">Topluluk üyelerimizin, Cursor Türkiye dışında kurumlar tarafından davet edildiği konuşma ve röportajlar.</span>
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {invites.map((invite) => {
              const typeLabelEn = invite.type === "interview" ? "Interview" : invite.type === "panel" ? "Panel" : "Talk";
              const typeLabelTr = invite.type === "interview" ? "Röportaj" : invite.type === "panel" ? "Panel" : "Konuşma";
              const inviteDate = formatInviteFullDate(invite.date);
              const inviteSlides = "slides" in invite && invite.slides && invite.slides.length > 0 ? invite.slides : null;
              const invitePhoto = "photos" in invite && invite.photos && invite.photos.length > 0 ? invite.photos[0] : null;
              return (
              <div class="bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden flex flex-col hover:border-[#444] transition-all">
                {invitePhoto && (
                  <div class="aspect-[16/10] w-full shrink-0 bg-[#0d1117] border-b border-[#252525] overflow-hidden">
                    <img
                      src={invitePhoto}
                      alt={invite.talkTitle}
                      class="w-full h-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="p-6 flex flex-col flex-grow">
                <div class="flex items-center gap-2 mb-4">
                  <span class:list={[
                    "text-[10px] font-mono border rounded px-2 py-0.5 uppercase tracking-wider",
                    invite.type === "interview"
                      ? "text-[#c084fc] border-[#c084fc]/25 bg-[#c084fc]/10"
                      : invite.type === "panel"
                        ? "text-[#f59e0b] border-[#f59e0b]/25 bg-[#f59e0b]/10"
                        : "text-[#58a6ff] border-[#58a6ff]/25 bg-[#58a6ff]/10",
                  ]}>
                    <span class="lang-en">{typeLabelEn}</span>
      <span class="lang-tr">{typeLabelTr}</span>
                  </span>
                  <span class="text-xs text-[#6E6E6E]">
                    <span class="lang-en">{inviteDate.en}</span>
      <span class="lang-tr">{inviteDate.tr}</span>
                  </span>
                </div>

                <h3 class="text-base font-semibold text-white mb-3 leading-snug">
                  <span class="lang-en">{invite.talkTitle}</span>
      <span class="lang-tr">{invite.talkTitle}</span>
                </h3>

                <div class="flex flex-col gap-3 mb-4">
                  {(() => {
                    const speakerInfo = speakerMap.get(invite.speaker.toLowerCase().trim());
                    const inviteSpeakerEn = speakerInfo?.name ?? invite.speaker;
                    const inviteSpeakerTr = speakerInfo?.nameTr ?? inviteSpeakerEn;
                    const InviteSpeakerTag = speakerInfo ? "a" : "span";
                    return (
                      <InviteSpeakerTag {...(speakerInfo ? { href: localizedPath(pagePath, `/speakers/${speakerInfo.slug}/`) } : {})} class={`flex items-center gap-1.5 text-xs text-[#6E6E6E] ${speakerInfo ? "hover:text-white cursor-pointer" : ""} transition-colors group/speaker`}>
                        {speakerInfo?.photo ? (
                          <img src={speakerInfo.photo} alt="" class="w-5 h-5 rounded-full object-cover shrink-0 border border-[#252525]" width="20" height="20" loading="lazy" />
                        ) : (
                          <span class="w-5 h-5 rounded-full bg-[#252525] border border-[#333] shrink-0 flex items-center justify-center text-[7px] font-bold text-[#8A8A8A]">{speakerInfo?.initials ?? invite.speaker.slice(0, 2).toUpperCase()}</span>
                        )}
                        <span class={`${speakerInfo ? "group-hover/speaker:text-white" : ""} transition-colors`}>
                          <span class="lang-en">{inviteSpeakerEn}</span>
      <span class="lang-tr">{inviteSpeakerTr}</span>
                        </span>
                      </InviteSpeakerTag>
                    );
                  })()}
                  <div class="flex items-center gap-2 text-xs text-[#999999]">
                    {"invitedByLogo" in invite && invite.invitedByLogo && (
                      <img
                        src={invite.invitedByLogo}
                        alt=""
                        class="w-5 h-5 rounded object-contain bg-[#0d0d0d] border border-[#252525] shrink-0 p-0.5"
                        width="20"
                        height="20"
                        loading="lazy"
                      />
                    )}
                    <span class="lang-en">
                      {invite.type === "interview" ? "interviewed by " : "invited by "}
                      <a
                        href={inviteInviterHref(invite.invitedByUrl)}
                        class="text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
                        {...(isSameSiteInviteUrl(invite.invitedByUrl) ? {} : { target: "_blank", rel: "noreferrer" })}
                      >
                        {invite.invitedBy}
                      </a>
                    </span>
                    <span class="lang-tr">
                      {invite.type === "interview" ? "Röportaj: " : "Davet eden: "}
                      <a
                        href={inviteInviterHref(invite.invitedByUrl)}
                        class="text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
                        {...(isSameSiteInviteUrl(invite.invitedByUrl) ? {} : { target: "_blank", rel: "noreferrer" })}
                      >
                        {invite.invitedByTr}
                      </a>
                    </span>
                  </div>
                </div>

                <div class="mt-auto pt-3 border-t border-[#252525] flex flex-wrap items-center gap-3">
                  <a
                    href={invite.postUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center gap-1.5 text-xs text-[#999999] hover:text-white transition-colors"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    <span class="lang-en">Post</span>
      <span class="lang-tr">Paylaşım</span>
                    <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                  {"recordingUrl" in invite && invite.recordingUrl && (
                    <a
                      href={invite.recordingUrl}
                      target="_blank"
                      rel="noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs text-[#999999] hover:text-white transition-colors"
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                      <span class="lang-en">Recording</span>
      <span class="lang-tr">Kayıt</span>
                      <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  )}
                  {inviteSlides &&
                    inviteSlides.map((url: string, i: number) => (
                      <a
                        href={url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center gap-1.5 text-xs text-[#58a6ff] hover:text-[#79c0ff] underline underline-offset-2"
                      >
                        <span class="lang-en">{inviteSlides.length > 1 ? `Slide ${i + 1}` : "Slides"}</span>
      <span class="lang-tr">{inviteSlides.length > 1 ? `Slayt ${i + 1}` : "Slaytlar"}</span>
                        <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                          <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    ))}
                </div>
                </div>
              </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </div>
</section>


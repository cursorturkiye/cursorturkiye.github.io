---
import { getEventsWithAlbums, getEventCoverUrl, getEventImageUrl, isVideo } from "@/utils/events";

const albums = await getEventsWithAlbums();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

function formatDateAr(date: Date) {
  return date.toLocaleDateString("ar-SA", { year: "numeric", month: "short", day: "numeric" });
}

function getAllMedia(event: { data: { photos?: string[]; videos?: string[] } }) {
  return [...(event.data.photos ?? []), ...(event.data.videos ?? [])];
}
---

<section id="albums">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">

    <!-- List View -->
    <div id="albums-list">
      <div class="mb-16 border-b border-[#252525] pb-8">
        <h1 class="text-4xl md:text-5xl font-semibold text-white mb-4">
          <span class="lang-en">Albums</span>
          <span class="lang-ar">ألبومات</span>
        </h1>
        <p class="text-[#999999] text-lg max-w-xl">
          <span class="lang-en">Photos & videos from our past events</span>
          <span class="lang-ar">صور وفيديوهات من فعالياتنا السابقة</span>
        </p>
      </div>

      {albums.length === 0 ? (
        <div class="py-16 text-center">
          <svg class="mx-auto mb-6 text-[#555]" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p class="text-[#999999] text-lg">
            <span class="lang-en">No albums yet</span>
            <span class="lang-ar">لا توجد ألبومات حالياً</span>
          </p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {albums.map((event) => {
            const coverUrl = getEventCoverUrl(event);
            const photoCount = event.data.photos?.length ?? 0;
            const videoCount = event.data.videos?.length ?? 0;
            return (
              <button
                class="album-card bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden hover:border-white/20 transition-all group text-start cursor-pointer"
                data-album-id={event.id}
                type="button"
              >
                <div class="aspect-[16/10] bg-[#1F1F1F] overflow-hidden">
                  {coverUrl ? (
                    <img
                      src={coverUrl}
                      alt={event.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-[#555]">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="text-lg font-semibold text-white mb-1 group-hover:text-white transition-colors">
                    <span class="lang-en">{event.data.title}</span>
                    <span class="lang-ar">{event.data.titleAr || event.data.title}</span>
                  </h3>
                  <div class="flex items-center gap-3 text-xs text-[#999999]">
                    <span>
                      <span class="lang-en">{formatDate(event.data.date)}</span>
                      <span class="lang-ar">{formatDateAr(event.data.date)}</span>
                    </span>
                    <span class="text-[#555]">·</span>
                    <span>
                      {photoCount > 0 && (
                        <>
                          <span class="lang-en">{photoCount} photos</span>
                          <span class="lang-ar">{photoCount.toLocaleString("ar-SA")} صور</span>
                        </>
                      )}
                      {photoCount > 0 && videoCount > 0 && <span class="text-[#555]"> · </span>}
                      {videoCount > 0 && (
                        <>
                          <span class="lang-en">{videoCount} {videoCount === 1 ? 'video' : 'videos'}</span>
                          <span class="lang-ar">{videoCount.toLocaleString("ar-SA")} {videoCount === 1 ? 'فيديو' : 'فيديوهات'}</span>
                        </>
                      )}
                    </span>
                  </div>
                  <div class="flex items-center gap-1.5 text-xs text-[#6E6E6E] mt-2">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span class="lang-en">{event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
                    <span class="lang-ar">{event.data.locationAr || event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
                  </div>
                </div>
              </button>
            );
          })}
        </div>
      )}
    </div>

    <!-- Detail Views (one per album, hidden by default) -->
    {albums.map((event) => {
      const media = getAllMedia(event);
      return (
        <div class="album-detail hidden" data-detail-id={event.id}>
          <button class="album-back-btn flex items-center gap-2 text-sm text-[#999999] hover:text-white transition-colors mb-8 cursor-pointer" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            <span class="lang-en">Back to Albums</span>
            <span class="lang-ar">العودة للألبومات</span>
          </button>

          <div class="mb-10 border-b border-[#252525] pb-8">
            <h1 class="text-3xl md:text-4xl font-semibold text-white mb-3">
              <span class="lang-en">{event.data.title}</span>
              <span class="lang-ar">{event.data.titleAr || event.data.title}</span>
            </h1>
            <div class="flex flex-wrap items-center gap-4 text-sm text-[#999999] mb-4">
              <span class="flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span class="lang-en">{formatDate(event.data.date)}</span>
                <span class="lang-ar">{formatDateAr(event.data.date)}</span>
              </span>
              <span class="flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span class="lang-en">{event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
                <span class="lang-ar">{event.data.locationAr || event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
              </span>
            </div>
            <p class="text-[#999999] max-w-2xl">
              <span class="lang-en">{event.data.description}</span>
              <span class="lang-ar">{event.data.descriptionAr || event.data.description}</span>
            </p>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
            {media.map((filename, idx) => {
              const src = getEventImageUrl(event.id, filename);
              const mediaIsVideo = isVideo(filename);
              return (
                <button
                  class="album-media aspect-square bg-[#1F1F1F] rounded-xl overflow-hidden cursor-pointer border border-[#252525] hover:border-white/20 transition-all group relative"
                  data-event-id={event.id}
                  data-media-idx={idx}
                  data-media-type={mediaIsVideo ? "video" : "image"}
                  type="button"
                >
                  {mediaIsVideo ? (
                    <>
                      <video
                        src={src}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        preload="metadata"
                        muted
                      />
                      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                        <div class="w-12 h-12 rounded-full bg-black/60 flex items-center justify-center">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                            <polygon points="6,3 20,12 6,21"/>
                          </svg>
                        </div>
                      </div>
                    </>
                  ) : (
                    <img
                      src={src}
                      alt={`${event.data.title} - ${idx + 1}`}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  )}
                </button>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Lightbox -->
  <div id="album-lightbox" class="fixed inset-0 z-[100] hidden bg-black/90 backdrop-blur-sm flex items-center justify-center">
    <button id="lightbox-close" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div id="lightbox-backdrop" class="absolute inset-0 -z-10"></div>
    <img id="lightbox-img" class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg hidden" src="" alt="" />
    <video id="lightbox-video" class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg hidden" controls playsinline></video>
    <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm text-white/70"></div>
  </div>
</section>

<script is:inline>
  (function () {
    var listView = document.getElementById('albums-list');
    var details = document.querySelectorAll('.album-detail');
    var lightbox = document.getElementById('album-lightbox');
    var lightboxImg = document.getElementById('lightbox-img');
    var lightboxVideo = document.getElementById('lightbox-video');
    var lightboxCounter = document.getElementById('lightbox-counter');
    var currentMedia = []; // [{src, type}]
    var currentIdx = 0;

    var VIDEO_EXTS = ['.mp4', '.webm', '.mov', '.ogg'];
    function isVideoSrc(src) {
      var lower = src.toLowerCase();
      for (var i = 0; i < VIDEO_EXTS.length; i++) {
        if (lower.indexOf(VIDEO_EXTS[i]) !== -1) return true;
      }
      return false;
    }

    // --- List / Detail switching ---
    function showAlbumDetail(eventId) {
      if (listView) listView.classList.add('hidden');
      details.forEach(function (d) { d.classList.add('hidden'); });
      var detail = document.querySelector('[data-detail-id="' + eventId + '"]');
      if (detail) detail.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showAlbumsList() {
      details.forEach(function (d) { d.classList.add('hidden'); });
      if (listView) listView.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Expose for SPA switchPage reset
    window.__albumsResetToList = showAlbumsList;

    document.querySelectorAll('.album-card').forEach(function (card) {
      card.addEventListener('click', function () {
        var id = this.getAttribute('data-album-id');
        if (id) showAlbumDetail(id);
      });
    });

    document.querySelectorAll('.album-back-btn').forEach(function (btn) {
      btn.addEventListener('click', showAlbumsList);
    });

    // --- Lightbox ---
    function openLightbox(eventId, idx) {
      var items = document.querySelectorAll('.album-media[data-event-id="' + eventId + '"]');
      currentMedia = [];
      items.forEach(function (el) {
        var type = el.getAttribute('data-media-type');
        var mediaEl = type === 'video' ? el.querySelector('video') : el.querySelector('img');
        if (mediaEl) {
          currentMedia.push({ src: mediaEl.getAttribute('src'), type: type });
        }
      });
      currentIdx = idx;
      updateLightbox();
      if (lightbox) lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (lightbox) lightbox.classList.add('hidden');
      document.body.style.overflow = '';
      // Pause any playing video
      if (lightboxVideo) {
        lightboxVideo.pause();
        lightboxVideo.removeAttribute('src');
      }
    }

    function updateLightbox() {
      var item = currentMedia[currentIdx];
      if (!item) return;

      if (item.type === 'video') {
        if (lightboxImg) lightboxImg.classList.add('hidden');
        if (lightboxVideo) {
          lightboxVideo.classList.remove('hidden');
          lightboxVideo.setAttribute('src', item.src);
          lightboxVideo.load();
        }
      } else {
        if (lightboxVideo) {
          lightboxVideo.pause();
          lightboxVideo.classList.add('hidden');
        }
        if (lightboxImg) {
          lightboxImg.classList.remove('hidden');
          lightboxImg.setAttribute('src', item.src);
          lightboxImg.setAttribute('alt', 'Media ' + (currentIdx + 1));
        }
      }

      if (lightboxCounter) {
        lightboxCounter.textContent = (currentIdx + 1) + ' / ' + currentMedia.length;
      }
    }

    function nextMedia() {
      if (lightboxVideo) lightboxVideo.pause();
      currentIdx = (currentIdx + 1) % currentMedia.length;
      updateLightbox();
    }

    function prevMedia() {
      if (lightboxVideo) lightboxVideo.pause();
      currentIdx = (currentIdx - 1 + currentMedia.length) % currentMedia.length;
      updateLightbox();
    }

    document.querySelectorAll('.album-media').forEach(function (el) {
      el.addEventListener('click', function () {
        var eventId = this.getAttribute('data-event-id');
        var idx = parseInt(this.getAttribute('data-media-idx'), 10);
        openLightbox(eventId, idx);
      });
    });

    var closeBtn = document.getElementById('lightbox-close');
    var prevBtn = document.getElementById('lightbox-prev');
    var nextBtn = document.getElementById('lightbox-next');
    var backdropEl = document.getElementById('lightbox-backdrop');
    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (prevBtn) prevBtn.addEventListener('click', prevMedia);
    if (nextBtn) nextBtn.addEventListener('click', nextMedia);
    if (backdropEl) backdropEl.addEventListener('click', closeLightbox);

    document.addEventListener('keydown', function (e) {
      if (lightbox && !lightbox.classList.contains('hidden')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') nextMedia();
        if (e.key === 'ArrowLeft') prevMedia();
      }
    });
  })();
</script>

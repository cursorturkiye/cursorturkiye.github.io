            )}
            {nextMecca && (
              <div class="border-t border-[#252525] pt-4">
                <div class="text-[9px] text-[#6E6E6E] uppercase tracking-widest mb-1"><span class="lang-en">Next Event</span><span class="lang-ar">الفعالية القادمة</span></div>
                <div class="text-xs text-white font-medium">{nextMecca.data.title}</div>
                <div class="text-[10px] text-[#999999] mt-0.5">{formatShortDate(nextMecca.data.date)}</div>
              </div>
            )}
            {meccaPartners.length > 0 && (
              <div class="border-t border-[#252525] pt-5 mt-5">
                <div class="text-[10px] uppercase tracking-widest text-[#6E6E6E] font-medium mb-4"><span class="lang-en">Chapter Partners</span><span class="lang-ar">شركاء الفرع</span></div>
                <div class="flex flex-wrap gap-3">
                  {meccaPartners.map((partner) => (
                    <a href={partner.url} target="_blank" rel="noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-[#252525] bg-[#1F1F1F] text-sm text-[#999999] hover:text-white hover:border-white/20 transition-all">
                      <img src={partner.logo} alt={partner.name} class="h-5 w-5 rounded object-cover" loading="lazy" />
                      <span class="lang-en">{partner.name}</span>
                      <span class="lang-ar">{partner.nameAr}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Ambassadors + Mission Pillars -->
    <div class="grid md:grid-cols-2 gap-12 items-start mb-24">
      <div class="space-y-6">
        {ambassadors.map((ambassador) => (
          <div class="bg-[#171717] border border-[#252525] rounded-2xl p-8 relative overflow-hidden">
            <div class="relative z-10">
              <div class="text-xs font-mono text-green-500 mb-1">
                <span class="lang-en">{ambassador.role} · {ambassador.city}</span>
                <span class="lang-ar">{ambassador.roleAr} · {ambassador.cityAr}</span>
              </div>
              <h2 class="text-2xl font-bold text-white mb-4">
                <span class="lang-en">{ambassador.name}</span>
                <span class="lang-ar">{ambassador.nameAr ?? ambassador.name}</span>
              </h2>
              <div class="flex gap-4">
                {ambassador.twitter && (
                  <a href={ambassador.twitter} target="_blank" rel="noreferrer" class="text-[#999999] hover:text-white transition-colors text-sm flex items-center gap-1.5">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    X
                  </a>
                )}
                {ambassador.linkedin && (
                  <a href={ambassador.linkedin} target="_blank" rel="noreferrer" class="text-[#999999] hover:text-white transition-colors text-sm flex items-center gap-1.5">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    LinkedIn
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}

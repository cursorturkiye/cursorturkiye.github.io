              {khobarAmbassador.linkedin && (
                <a href={khobarAmbassador.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
            </div>
          </div>
          <div class="flex gap-4 mb-6">
            <div><div class="text-xl font-bold text-white">{khobarPast}</div><div class="text-[10px] text-[#999999] uppercase tracking-wider"><span class="lang-en">Completed</span><span class="lang-ar">مكتملة</span></div></div>
            <div><div class="text-xl font-bold text-white">{khobarUpcoming}</div><div class="text-[10px] text-[#999999] uppercase tracking-wider"><span class="lang-en">Upcoming</span><span class="lang-ar">قادمة</span></div></div>
          </div>
          {nextKhobar && (
            <div class="border-t border-[#252525] pt-4">
              <div class="text-[9px] text-[#6E6E6E] uppercase tracking-widest mb-1"><span class="lang-en">Next Event</span><span class="lang-ar">الفعالية القادمة</span></div>
              <div class="text-xs text-white font-medium">{nextKhobar.data.title}</div>
              <div class="text-[10px] text-[#999999] mt-0.5">{formatShortDate(nextKhobar.data.date)}</div>
            </div>
          )}
          {khobarPartners.length > 0 && (
            <div class="border-t border-[#252525] pt-5 mt-5">
              <div class="text-[10px] uppercase tracking-widest text-[#6E6E6E] font-medium mb-4"><span class="lang-en">Chapter Partners</span><span class="lang-ar">شركاء الفرع</span></div>
              <div class="flex flex-wrap gap-3">
                {khobarPartners.map((partner) => (
                  <a href={partner.url} target="_blank" rel="noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-lg border border-[#252525] bg-[#1F1F1F] text-sm text-[#999999] hover:text-white hover:border-white/20 transition-all">
                    <img src={partner.logo} alt={partner.name} class="h-5 w-5 rounded object-cover" loading="lazy" />
                    <span class="lang-en">{partner.name}</span>
                    <span class="lang-ar">{partner.nameAr}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Mecca Chapter -->
        <div id="mecca-chapter" class="bg-[#171717] border border-[#252525] rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-transparent pointer-events-none"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <span class="w-2.5 h-2.5 rounded-full bg-purple-400 shadow-[0_0_8px_rgba(192,132,252,0.6)]"></span>
                <h3 class="text-xl font-semibold text-white"><span class="lang-en">Mecca Chapter</span><span class="lang-ar">فرع مكة المكرمة</span></h3>
              </div>
              <span class="text-xs font-mono text-purple-400 border border-purple-500/30 bg-purple-500/10 rounded px-2 py-1">
                <span class="lang-en">COMING SOON</span>
                <span class="lang-ar">قريباً</span>
              </span>
            </div>
            <p class="text-sm text-[#999999] mb-4"><span class="lang-en">Expanding to the Holy City to serve the growing tech community in the Mecca region. Stay tuned for our first events.</span><span class="lang-ar">نتوسع إلى مكة المكرمة لخدمة مجتمع التقنية المتنامي في منطقة مكة. ترقبوا فعالياتنا الأولى.</span></p>
            <div class="flex items-center gap-2 text-xs text-[#999999] mb-4">
              {meccaAmbassador ? (
                <>
                  <span class="lang-en">{meccaAmbassador.role}:</span><span class="lang-ar">{meccaAmbassador.roleAr}:</span>

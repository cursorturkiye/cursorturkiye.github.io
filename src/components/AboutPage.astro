---
import { config } from "@/config";
import { getUpcomingEvents, getPastEvents } from "@/utils/events";
import type { CollectionEntry } from "astro:content";

type EventEntry = CollectionEntry<"events">;

interface Ambassador {
  name: string;
  nameAr?: string;
  role: string;
  roleAr: string;
  city: string;
  cityAr: string;
  photo?: string;
  description?: string;
  descriptionAr?: string;
  email?: string;
  twitter?: string;
  /** Display handle for X (without @). */
  twitterHandle?: string;
  linkedin?: string;
  status?: "active" | "retired";
}

const ambassadors = config.ambassadors as readonly Ambassador[];

const upcoming = await getUpcomingEvents();
const past = await getPastEvents();

const riyadhPast = past.filter((e: EventEntry) => e.data.location === "Riyadh").length;
const riyadhUpcoming = upcoming.filter((e: EventEntry) => e.data.location === "Riyadh").length;
const khobarPast = past.filter((e: EventEntry) => e.data.location === "Khobar").length;
const khobarUpcoming = upcoming.filter((e: EventEntry) => e.data.location === "Khobar").length;
const jeddahPast = past.filter((e: EventEntry) => e.data.location === "Jeddah").length;
const jeddahUpcoming = upcoming.filter((e: EventEntry) => e.data.location === "Jeddah").length;

const nextRiyadh = upcoming.find((e: EventEntry) => e.data.location === "Riyadh");
const nextKhobar = upcoming.find((e: EventEntry) => e.data.location === "Khobar");
const nextJeddah = upcoming.find((e: EventEntry) => e.data.location === "Jeddah");

const riyadhAmbassador = ambassadors.find((a) => a.city === "Riyadh")!;
const khobarAmbassador = ambassadors.find((a) => a.city === "Khobar")!;
const jeddahAmbassador = ambassadors.find((a) => a.city === "Jeddah");

const riyadhPartners = config.partners.filter((p) => (p.cities as readonly string[]).includes("Riyadh") && p.role !== "past-community-partner");
const khobarPartners = config.partners.filter((p) => (p.cities as readonly string[]).includes("Khobar"));
const jeddahPartners = config.partners.filter((p) => (p.cities as readonly string[]).includes("Jeddah"));

function formatShortDate(date: Date) {
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
---

<section id="about">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">
    <!-- Mission Statement -->
    <div class="max-w-4xl mx-auto text-center mb-20">
      <h1 class="text-4xl md:text-5xl font-semibold text-white mb-8">
        <span class="lang-en">Empowering the Kingdom's<br>Next Generation of Builders.</span>
        <span class="lang-ar">تمكين الجيل القادم<br>من البناة في المملكة.</span>
      </h1>
      <p class="text-xl text-[#999999] leading-relaxed">
        <span class="lang-en">Cursor Saudi is a community-led initiative dedicated to accelerating the adoption of AI-native development tools across Saudi Arabia. We believe the future of software is collaborative, intelligent, and open.</span>
        <span class="lang-ar">Cursor Saudi هي مبادرة مجتمعية مكرسة لتسريع تبني أدوات التطوير المدعومة بالذكاء الاصطناعي في المملكة العربية السعودية. نؤمن بأن مستقبل البرمجيات تعاوني وذكي ومفتوح.</span>
      </p>
    </div>

    <!-- Event Types -->
    <div class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
          <span class="lang-en">What We Do</span>
          <span class="lang-ar">ماذا نقدم</span>
        </span>
        <h2 class="text-3xl font-semibold text-white mt-3">
          <span class="lang-en">Our Events</span>
          <span class="lang-ar">فعالياتنا</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
        <!-- Cursor Meetup -->
        <div class="bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden flex flex-col">
          <img src="/images/event-types/hackathon-riyadh.jpg" alt="Cursor meetups and community in Riyadh" class="w-full h-40 object-cover" loading="lazy" />
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-mono text-[#58a6ff] border border-[#58a6ff]/25 bg-[#58a6ff]/10 rounded px-2 py-1">
                <span class="lang-en">~2 hours</span>
                <span class="lang-ar">~ساعتين</span>
              </span>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              <span class="lang-en">Cursor Meetup</span>
              <span class="lang-ar">لقاء كيرسر</span>
            </h3>
            <p class="text-sm text-[#999999] leading-relaxed">
              <span class="lang-en">Knowledge-sharing meetups and workshops — talks, demos, and hands-on sessions covering Cursor workflows, MCP servers, prompt engineering, and AI-native development.</span>
              <span class="lang-ar">لقاءات لنشر المعرفة — عروض تقديمية وجلسات عملية تغطي سير عمل Cursor وخوادم MCP وهندسة البرومبت والتطوير بالذكاء الاصطناعي.</span>
            </p>
          </div>
        </div>

        <!-- Cursor Building Session -->
        <div class="bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden flex flex-col">
          <img src="/images/event-types/building-session-riyadh.jpeg" alt="Cursor Building Session in Riyadh" class="w-full h-40 object-cover" loading="lazy" />
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-mono text-green-400 border border-green-400/25 bg-green-400/10 rounded px-2 py-1">
                <span class="lang-en">4–6 hours</span>
                <span class="lang-ar">٤-٦ ساعات</span>
              </span>
              <span class="text-[10px] font-mono text-amber-400 border border-amber-400/25 bg-amber-400/10 rounded px-2 py-1">
                <span class="lang-en">Free Credits</span>
                <span class="lang-ar">كريدتس مجانية</span>
              </span>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              <span class="lang-en">Cursor Building Session</span>
              <span class="lang-ar">جلسة بناء كيرسر</span>
            </h3>
            <p class="text-sm text-[#999999] leading-relaxed">
              <span class="lang-en">Hands-on building sessions where attendees ship real products using AI tools. Cursor provides free credits for all participants.</span>
              <span class="lang-ar">جلسات بناء عملية يبني فيها الحضور منتجات حقيقية باستخدام أدوات الذكاء الاصطناعي. كيرسر يوفر كريدتس مجانية لجميع الحضور.</span>
            </p>
          </div>
        </div>

        <!-- Cafe Cursor -->
        <div class="bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden flex flex-col">
          <img
            src="/images/event-types/cafe-cursor-sf.png"
            alt="Cafe Cursor, San Francisco"
            class="w-full h-40 object-cover"
            loading="lazy"
          />
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-mono text-purple-400 border border-purple-400/25 bg-purple-400/10 rounded px-2 py-1">
                <span class="lang-en">6–12 hours</span>
                <span class="lang-ar">٦-١٢ ساعة</span>
              </span>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              <span class="lang-en">Cafe Cursor</span>
              <span class="lang-ar">مقهى كيرسر</span>
            </h3>
            <p class="text-sm text-[#999999] leading-relaxed">
              <span class="lang-en">Casual co-working at a local cafe — the same format Cursor runs globally (for example New York and San Francisco). We gather to work, network, and connect in a relaxed setting.</span>
              <span class="lang-ar">عمل مشترك في مقهى محلي — نفس الأسلوب الذي تنظمه كيرسر عالمياً (مثل نيويورك وسان فرانسيسكو). نجتمع للعمل والتعارف والتواصل بأجواء مريحة.</span>
            </p>
          </div>
        </div>

        <!-- Hackathon -->
        <div class="bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden flex flex-col">
          <img src="/placeholders/event-card.svg" alt="" class="w-full h-40 object-cover bg-[#0d1117]" loading="lazy" />
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-mono text-red-400/80 border border-red-400/20 bg-red-400/5 rounded px-2 py-1">
                <span class="lang-en">~12 hours</span>
                <span class="lang-ar">~١٢ ساعة</span>
              </span>
              <span class="text-[10px] font-mono text-amber-400 border border-amber-400/25 bg-amber-400/10 rounded px-2 py-1">
                <span class="lang-en">Free Credits</span>
                <span class="lang-ar">كريدتس مجانية</span>
              </span>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">
              <span class="lang-en">Cursor Hackathon</span>
              <span class="lang-ar">هاكاثون كيرسر</span>
            </h3>
            <p class="text-sm text-[#999999] leading-relaxed">
              <span class="lang-en">Large-scale hackathons in partnership with local organizations — often a full ~12-hour day, with Cursor free credits for participants — building, competing, and shipping together.</span>
              <span class="lang-ar">هاكاثونات كبيرة بشراكة مع جهات محلية — غالباً يوم كامل حوالي ١٢ ساعة، مع كريدتس مجانية من كيرسر للمشاركين — نبني ونتنافس وننجز معاً.</span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Chapters Section -->
    <div class="mb-24">
      <div class="text-center mb-12">
        <span class="text-xs font-mono text-[#999999] uppercase tracking-widest">
          <span class="lang-en">Our Chapters</span>
          <span class="lang-ar">فروعنا</span>
        </span>
        <h2 class="text-3xl font-semibold text-white mt-3">
          <span class="lang-en">Active Across the Kingdom</span>
          <span class="lang-ar">نشطون في أنحاء المملكة</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 items-stretch">
        <!-- Riyadh Chapter -->
        <div id="riyadh-chapter" class="bg-[#171717] border border-[#252525] rounded-2xl p-8 h-full flex flex-col">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></span>
              <h3 class="text-xl font-semibold text-white"><span class="lang-en">Riyadh Chapter</span><span class="lang-ar">فرع الرياض</span></h3>
            </div>
            <span class="text-xs font-mono text-[#999999] border border-[#252525] rounded px-2 py-1">EST. 2025</span>
          </div>
          <p class="text-sm text-[#999999] mb-4"><span class="lang-en">The flagship chapter — home to the largest community of Cursor developers in the Kingdom. Regular meetups, workshops, and build sprints covering AI-native development, MCP servers, prompt engineering, and more.</span><span class="lang-ar">الفرع الرئيسي — موطن أكبر مجتمع مطورين لـ Cursor في المملكة. لقاءات وورش عمل وسباقات بناء منتظمة تغطي التطوير بالذكاء الاصطناعي وخوادم MCP وهندسة البرومبت والمزيد.</span></p>
          <div class="flex items-center gap-2 text-xs text-[#999999] mb-4">
            <span class="lang-en">{riyadhAmbassador.role}:</span><span class="lang-ar">{riyadhAmbassador.roleAr}:</span>
            <div class="flex items-center gap-2">
              <span class="lang-en text-white font-medium">{riyadhAmbassador.name}</span>
                <span class="lang-ar text-white font-medium">{riyadhAmbassador.nameAr ?? riyadhAmbassador.name}</span>
              {riyadhAmbassador.twitter && (
                <a href={riyadhAmbassador.twitter} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="X / Twitter">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              )}
              {riyadhAmbassador.linkedin && (
                <a href={riyadhAmbassador.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
            </div>
          </div>
          <div class="flex gap-4 mb-6">
            <div><div class="text-xl font-bold text-white">{riyadhPast}</div><div class="text-[10px] text-[#999999] uppercase tracking-wider"><span class="lang-en">Completed</span><span class="lang-ar">مكتملة</span></div></div>
            <div><div class="text-xl font-bold text-white">{riyadhUpcoming}</div><div class="text-[10px] text-[#999999] uppercase tracking-wider"><span class="lang-en">Upcoming</span><span class="lang-ar">قادمة</span></div></div>
          </div>
          {nextRiyadh && (
            <div class="border-t border-[#252525] pt-4">
              <div class="text-[9px] text-[#6E6E6E] uppercase tracking-widest mb-1"><span class="lang-en">Next Event</span><span class="lang-ar">الفعالية القادمة</span></div>
              <div class="text-xs text-white font-medium">{nextRiyadh.data.title}</div>
              <div class="text-[10px] text-[#999999] mt-0.5">{formatShortDate(nextRiyadh.data.date)}</div>
            </div>
          )}
          {riyadhPartners.length > 0 && (
            <div class="border-t border-[#252525] pt-4 mt-4">
              <div class="text-[10px] uppercase tracking-widest text-[#6E6E6E] font-medium mb-3"><span class="lang-en">Chapter Partners</span><span class="lang-ar">شركاء الفرع</span></div>
              <div class="grid w-full min-w-0 grid-cols-2 gap-2 sm:grid-cols-3">
                {riyadhPartners.map((partner) => (
                  <a
                    href={partner.url}
                    target="_blank"
                    rel="noreferrer"
                    class="flex min-h-[2.75rem] min-w-0 items-center justify-center rounded-lg border border-[#252525] bg-[#1F1F1F] px-2 py-2 transition-colors hover:border-white/25"
                  >
                    <img
                      src={partner.logo}
                      alt={partner.name}
                      class="h-7 max-h-7 w-full max-w-[6.5rem] object-contain object-center"
                      loading="lazy"
                    />
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Khobar Chapter -->
        <div id="khobar-chapter" class="bg-[#171717] border border-[#252525] rounded-2xl p-8 h-full flex flex-col">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 shadow-[0_0_8px_rgba(250,204,21,0.8)]"></span>
              <h3 class="text-xl font-semibold text-white"><span class="lang-en">Khobar Chapter</span><span class="lang-ar">فرع الخبر</span></h3>
            </div>
            <span class="text-xs font-mono text-[#999999] border border-[#252525] rounded px-2 py-1">EST. 2025</span>
          </div>
          <p class="text-sm text-[#999999] mb-4"><span class="lang-en">Building the Khobar chapter and connecting engineers across Khobar, Dammam, and Dhahran with a focus on AI-powered development workflows.</span><span class="lang-ar">نبني فرع الخبر ونربط المهندسين في الخبر والدمام والظهران مع التركيز على سير عمل التطوير المدعوم بالذكاء الاصطناعي.</span></p>
          <div class="space-y-4 mb-4 text-xs text-[#999999]">
            <div>
              <div class="text-[10px] uppercase tracking-widest text-amber-500/90 font-medium mb-1">
                <span class="lang-en">Former ambassador · Retired</span>
                <span class="lang-ar">سفير سابق · متقاعد</span>
              </div>
              <div class="flex flex-wrap items-center gap-2 text-[#999999]">
                <span class="lang-en line-through decoration-white/25 text-white/70 font-medium">{khobarAmbassador.name}</span>
                <span class="lang-ar line-through decoration-white/25 text-white/70 font-medium">{khobarAmbassador.nameAr ?? khobarAmbassador.name}</span>
                {khobarAmbassador.twitter && (
                  <a href={khobarAmbassador.twitter} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="X / Twitter">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                )}
                {khobarAmbassador.linkedin && (
                  <a href={khobarAmbassador.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                )}
              </div>
            </div>
            <div class="border-t border-[#252525] pt-4 flex gap-4">
              <div><div class="text-xl font-bold text-white">{khobarPast}</div><div class="text-[10px] text-[#999999] uppercase tracking-wider"><span class="lang-en">Completed</span><span class="lang-ar">مكتملة</span></div></div>
              <div><div class="text-xl font-bold text-white">{khobarUpcoming}</div><div class="text-[10px] text-[#999999] uppercase tracking-wider"><span class="lang-en">Upcoming</span><span class="lang-ar">قادمة</span></div></div>
            </div>
            <div class="border-t border-[#252525] pt-3">
              <div class="text-[10px] uppercase tracking-widest text-green-500/90 font-medium mb-2">
                <span class="lang-en">Looking for</span>
                <span class="lang-ar">نبحث عن</span>
              </div>
              <p class="text-sm text-[#b0b0b0] leading-relaxed">
                <span class="lang-en">
                  We are looking for an ambassador to lead the <strong class="text-white/90 font-medium">Khobar chapter</strong> and grow
                  meetups for builders in Khobar, Dhahran, and Dammam.
                </span>
                <span class="lang-ar">
                  نبحث عن سفير يقود <strong class="text-white/90 font-medium">فرع الخبر</strong> وينمّي اللقاءات للمبدعين في الخبر والظهران والدمام.
                </span>
              </p>
              <a href="/ambassadors" class="mt-3 text-xs font-medium text-[#58a6ff] hover:text-[#79c0ff] transition-colors">
                <span class="lang-en">Ambassador program &amp; how to apply →</span>
                <span class="lang-ar">برنامج السفراء وكيفية التقديم ←</span>
              </a>
            </div>
          </div>
          {nextKhobar && (
            <div class="border-t border-[#252525] pt-4">
              <div class="text-[9px] text-[#6E6E6E] uppercase tracking-widest mb-1"><span class="lang-en">Next Event</span><span class="lang-ar">الفعالية القادمة</span></div>
              <div class="text-xs text-white font-medium">{nextKhobar.data.title}</div>
              <div class="text-[10px] text-[#999999] mt-0.5">{formatShortDate(nextKhobar.data.date)}</div>
            </div>
          )}
          {khobarPartners.length > 0 && (
            <div class="border-t border-[#252525] pt-4 mt-4">
              <div class="text-[10px] uppercase tracking-widest text-[#6E6E6E] font-medium mb-3"><span class="lang-en">Chapter Partners</span><span class="lang-ar">شركاء الفرع</span></div>
              <div class="grid w-full min-w-0 grid-cols-2 gap-2 sm:grid-cols-3">
                {khobarPartners.map((partner) => (
                  <a
                    href={partner.url}
                    target="_blank"
                    rel="noreferrer"
                    class="flex min-h-[2.75rem] min-w-0 items-center justify-center rounded-lg border border-[#252525] bg-[#1F1F1F] px-2 py-2 transition-colors hover:border-white/25"
                  >
                    <img
                      src={partner.logo}
                      alt={partner.name}
                      class="h-7 max-h-7 w-full max-w-[6.5rem] object-contain object-center"
                      loading="lazy"
                    />
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Jeddah Chapter -->
        <div id="jeddah-chapter" class="bg-[#171717] border border-[#252525] rounded-2xl p-8 relative overflow-hidden h-full flex flex-col">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-transparent pointer-events-none"></div>
          <div class="relative z-10 flex flex-col flex-grow min-h-0">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3 min-w-0">
                <span class="w-2.5 h-2.5 rounded-full bg-purple-400 shadow-[0_0_8px_rgba(192,132,252,0.6)] shrink-0"></span>

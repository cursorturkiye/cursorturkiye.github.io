---
import BlogCard from "@/components/BlogCard.astro";
import { getAllBlogPosts } from "@/utils/blog";

const posts = await getAllBlogPosts();
---

<section id="blog" class="page-content">
  <div class="max-w-5xl mx-auto px-6 md:px-10 py-12 md:py-20">
    <div class="mb-16 max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-semibold text-white mb-4">
        <span class="lang-en">Intelligence Log</span>
        <span class="lang-ar">سجل المعرفة</span>
      </h1>
      <p class="text-[#8A8A8A] text-lg">
        <span class="lang-en">Technical guides, case studies, and updates from the ecosystem.</span>
        <span class="lang-ar">أدلة تقنية ودراسات حالة وتحديثات من المنظومة.</span>
      </p>
    </div>

    {posts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-16 h-16 rounded-2xl bg-[#0F0F0F] border border-[#2A2A2A] flex items-center justify-center mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4A4A4A" stroke-width="1.5" aria-hidden="true">
            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-semibold text-white mb-3">
          <span class="lang-en">Coming Soon</span>
          <span class="lang-ar">قريباً</span>
        </h2>
        <p class="text-[#8A8A8A] max-w-md">
          <span class="lang-en">We're working on technical guides and community stories. Stay tuned for updates from the Cursor Saudi ecosystem.</span>
          <span class="lang-ar">نعمل على أدلة تقنية وقصص من المجتمع. ترقبوا التحديثات من منظومة Cursor Saudi.</span>
        </p>
      </div>
    )}
  </div>
</section>

---
import LangToggle from "@/components/LangToggle.astro";
import { localizedPath, stripLocalePrefix } from "@/utils/i18n-path";

const navItems = [
  { id: "home", href: "/", en: "Home", tr: "Ana Sayfa" },
  { id: "events", href: "/events", en: "Events", tr: "Etkinlikler" },
  { id: "albums", href: "/albums", en: "Albums", tr: "Albümler" },
  { id: "about", href: "/about", en: "About", tr: "Hakkında" },
  { id: "ambassadors", href: "/ambassadors", en: "Become an ambassador", tr: "Elçi Ol" },
  { id: "partnerships", href: "/partnerships", en: "Work with us", tr: "Bizimle Çalışın" },
  { id: "thankyou", href: "/thankyou", en: "Thank You", tr: "Teşekkürler" },
];

const pagePath = Astro.url.pathname;
const barePath = stripLocalePrefix(pagePath).replace(/\/$/, "") || "/";

function isActive(href: string) {
  const h = href === "/" ? "/" : href.replace(/\/$/, "") || "/";
  if (h === "/") return barePath === "/" || barePath === "";
  return barePath === h || barePath.startsWith(h + "/");
}
---

<nav class="fixed top-0 left-0 right-0 z-50 glass-nav h-[72px] flex items-center">
  <div class="max-w-7xl mx-auto w-full px-6 md:px-10 flex items-center justify-between">
    <!-- Logo -->
    <a href={localizedPath(pagePath, "/")} class="flex items-center group cursor-pointer" aria-label="Cursor Türkiye - Home">
      <svg width="22" height="25" viewBox="0 0 467 532" fill="none" class="logo-cursor" aria-hidden="true">
        <path d="M457.43,125.94L244.42,2.96c-6.84-3.95-15.28-3.95-22.12,0L9.3,125.94c-5.75,3.32-9.3,9.46-9.3,16.11v247.99c0,6.65,3.55,12.79,9.3,16.11l213.01,122.98c6.84,3.95,15.28,3.95,22.12,0l213.01-122.98c5.75-3.32,9.3-9.46,9.3-16.11v-247.99c0-6.65-3.55-12.79-9.3-16.11h-.01ZM444.05,151.99l-205.63,356.16c-1.39,2.4-5.06,1.42-5.06-1.36v-233.21c0-4.66-2.49-8.97-6.53-11.31L24.87,145.67c-2.4-1.39-1.42-5.06,1.36-5.06h411.26c5.84,0,9.49,6.33,6.57,11.39h-.01Z" fill="#15803d"/>
      </svg>
    </a>

    <!-- Desktop nav from xl up; hamburger only below xl -->
    <div class="hidden xl:flex items-center gap-5 min-w-0 shrink xl:gap-6 2xl:gap-8">
      {navItems.map((item) => (
        <a
          href={localizedPath(pagePath, item.href === "/" ? "/" : `${item.href}/`)}
          class={`nav-link${isActive(item.href) ? " active" : ""}`}
          id={`nav-${item.id}`}
          {...(isActive(item.href) ? { "aria-current": "page" } : {})}
        >
          <span class="lang-tr">{item.ar}</span>
          <span class="lang-en">{item.en}</span>
        </a>
      ))}
    </div>

    <!-- Right side actions -->
    <div class="flex items-center gap-3">
      <LangToggle />
      <a href="https://discord.gg/KpsKtegvz4" target="_blank" rel="noreferrer" class="hidden xl:inline-flex items-center gap-2 btn-primary px-5 py-2 rounded-full text-sm font-medium">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        <span class="lang-tr">Topluluğa Katıl</span>
        <span class="lang-en">Join Community</span>
      </a>

      <!-- Hamburger: viewports < xl only -->
      <button
        id="mobile-menu-btn"
        class="xl:hidden flex items-center justify-center w-9 h-9 rounded-lg border border-white/10 bg-white/5 text-white hover:bg-white/10 transition-colors shrink-0"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="menu-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 hidden" aria-hidden="true">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="mobile-menu-backdrop"></div>
  <div class="absolute top-[72px] left-0 right-0 bg-[#0F0F0F] border-b border-[#252525] shadow-2xl">
    <div class="flex flex-col p-6 gap-1">
      {navItems.map((item) => (
        <a
          href={localizedPath(pagePath, item.href === "/" ? "/" : `${item.href}/`)}
          class={`mobile-nav-link nav-link text-start py-3 px-4 rounded-xl text-base font-medium ${isActive(item.href) ? "active text-white" : "text-[#999999]"} hover:text-white hover:bg-white/5 transition-colors`}
          {...(isActive(item.href) ? { "aria-current": "page" } : {})}
        >
          <span class="lang-tr">{item.ar}</span>
          <span class="lang-en">{item.en}</span>
        </a>
      ))}
      <div class="border-t border-[#252525] mt-3 pt-4">
        <a href="https://discord.gg/KpsKtegvz4" target="_blank" rel="noreferrer" class="btn-primary w-full px-5 py-3 rounded-full text-sm font-medium flex items-center justify-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          <span class="lang-tr">Topluluğa Katıl</span>
          <span class="lang-en">Join Community</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var backdrop = document.getElementById('mobile-menu-backdrop');
    var iconOpen = document.getElementById('menu-icon-open');
    var iconClose = document.getElementById('menu-icon-close');
    if (!btn || !menu) return;

    function isOpen() {
      return !menu.classList.contains('hidden');
    }

    function openMenu() {
      menu.classList.remove('hidden');
      menu.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      document.addEventListener('keydown', onKeyDown);
      var firstLink = menu.querySelector('.mobile-nav-link');
      if (firstLink) firstLink.focus();
    }

    function closeMenu() {
      menu.classList.add('hidden');
      menu.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKeyDown);
      btn.focus();
    }

    function toggle() {
      if (isOpen()) closeMenu(); else openMenu();
    }

    function onKeyDown(e) {
      if (e.key === 'Escape') {
        closeMenu();
        return;
      }
      if (e.key !== 'Tab') return;
      var focusable = menu.querySelectorAll('a[href], button, [tabindex]:not([tabindex="-1"])');
      if (focusable.length === 0) return;
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    btn.addEventListener('click', toggle);
    if (backdrop) backdrop.addEventListener('click', closeMenu);

    menu.querySelectorAll('.mobile-nav-link').forEach(function (link) {
      link.addEventListener('click', function () {
        if (isOpen()) closeMenu();
      });
    });
  })();
</script>


---
import { config } from "@/config";

const email = config.social.email;
const { luma, discord, twitter } = config.social;
const mail = (subject: string) =>
  `mailto:${email}?subject=${encodeURIComponent(subject)}`;
---

<section id="partnerships">
  <div class="max-w-3xl mx-auto px-6 md:px-10 py-12 md:py-20">
    <p class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-4">
      <span class="lang-en">Organizations &amp; builders</span>
      <span class="lang-ar">الجهات والمبدعون</span>
    </p>
    <h1 class="text-3xl md:text-4xl font-semibold text-white mb-6">
      <span class="lang-en">Work with us</span>
      <span class="lang-ar">اعمل معنا</span>
    </h1>
    <p class="text-lg text-[#999999] leading-relaxed mb-14">
      <span class="lang-en">
        Whether you represent a company, a venue, a community, or you are an individual — here is how you can <strong class="text-white font-medium">support</strong> Cursor Saudi, <strong class="text-white font-medium">join</strong> what we run, or <strong class="text-white font-medium">engage</strong> us for training and media. Email is the main line; we also hang out on Discord, post events on Luma, and share updates on X.
      </span>
      <span class="lang-ar">
        سواء كنت تمثّل شركة أو مكاناً أو مجتمعاً أو فرداً — إليك كيف يمكنك <strong class="text-white font-medium">دعم</strong> كيرسر السعودية، أو <strong class="text-white font-medium">المشاركة</strong> في ما نقيمه، أو <strong class="text-white font-medium">التعاون</strong> معنا في التدريب والإعلام. البريد هو الخط الأساسي؛ ونلتقي أيضاً على ديسكورد، وننشر الفعاليات على Luma، والتحديثات على X.
      </span>
    </p>

    <!-- Support the community -->
    <div id="support-community" class="mb-16 scroll-mt-24">
      <h2 class="text-xl font-semibold text-white mb-2">
        <span class="lang-en">Support the community</span>
        <span class="lang-ar">ادعم المجتمع</span>
      </h2>
      <p class="text-sm text-[#8b949e] mb-6 leading-relaxed">
        <span class="lang-en">Help us run meetups, workshops, and hackathons across Saudi Arabia.</span>
        <span class="lang-ar">ساعدنا على تنظيم اللقاءات والورش وهاكاثونات البناء في أنحاء المملكة.</span>
      </p>
      <div class="space-y-4">
        <div class="bg-[#171717] border border-[#252525] rounded-xl p-5 md:p-6">
          <h3 class="text-white font-medium mb-2">
            <span class="lang-en">Community partners</span>
            <span class="lang-ar">شركاء مجتمعيون</span>
          </h3>
          <p class="text-sm text-[#999999] leading-relaxed">
            <span class="lang-en">Help with logistics and other factors — promotion, volunteer coordination, registration support, swag, or connecting us with the right people.</span>
            <span class="lang-ar">المساعدة في اللوجستيات وعوامل أخرى — الترويق، تنسيق المتطوعين، التسجيل، الهدايا التذكارية، أو ربطنا بالجهات المناسبة.</span>
          </p>
        </div>
        <div class="bg-[#171717] border border-[#252525] rounded-xl p-5 md:p-6">
          <h3 class="text-white font-medium mb-2">
            <span class="lang-en">Venue host partners</span>
            <span class="lang-ar">شركاء استضافة المكان</span>
          </h3>
          <p class="text-sm text-[#999999] leading-relaxed">
            <span class="lang-en">Provide a space — room capacity, seating, Wi‑Fi, and basic AV for community events.</span>
            <span class="lang-ar">توفير مكان — سعة القاعة، الجلوس، الواي فاي، وتجهيزات عرض أساسية للفعاليات المجتمعية.</span>
          </p>
        </div>
        <div class="bg-[#171717] border border-[#252525] rounded-xl p-5 md:p-6">
          <h3 class="text-white font-medium mb-2">
            <span class="lang-en">Sponsorship partners</span>
            <span class="lang-ar">شركاء الرعاية</span>
          </h3>
          <p class="text-sm text-[#999999] leading-relaxed">
            <span class="lang-en">Help cover costs — sponsorship, catering, travel, or other line items that keep events accessible.</span>
            <span class="lang-ar">المساعدة في تغطية التكاليف — الرعاية، الضيافة، السفر، أو بنود أخرى تجعل الفعاليات في متناول الجميع.</span>
          </p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-2">
        <a href={luma} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
          <span class="lang-en">Events on Luma ↗</span>
          <span class="lang-ar">الفعاليات على Luma ↗</span>
        </a>
        <a href={discord} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
          <span class="lang-en">Discord ↗</span>
          <span class="lang-ar">ديسكورد ↗</span>
        </a>
        <a href={twitter} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
          <span class="lang-en">X / Twitter ↗</span>
          <span class="lang-ar">X ↗</span>
        </a>
      </div>
    </div>

    <!-- Be part of the community -->
    <div id="part-of-community" class="mb-16 scroll-mt-24">
      <h2 class="text-xl font-semibold text-white mb-2">
        <span class="lang-en">Be part of the community</span>
        <span class="lang-ar">كن جزءاً من المجتمع</span>
      </h2>
      <p class="text-sm text-[#8b949e] mb-6 leading-relaxed">
        <span class="lang-en">Share your voice and ideas with builders in the Kingdom.</span>
        <span class="lang-ar">شارك صوتك وأفكارك مع المبدعين في المملكة.</span>
      </p>
      <div class="bg-[#171717] border border-[#252525] rounded-xl p-5 md:p-6">
        <h3 class="text-white font-medium mb-2">
          <span class="lang-en">Speaker requests</span>
          <span class="lang-ar">طلبات المتحدثين</span>
        </h3>
        <p class="text-sm text-[#999999] leading-relaxed mb-4">
          <span class="lang-en">Do you have a topic you care about that you think people will find interesting? Propose a talk, panel idea, or hands-on session — we prioritize inclusive, practical formats.</span>
          <span class="lang-ar">هل لديك موضوع تهتم به وتظن أن الآخرين سيجدونه مفيداً؟ اقترح محاضرة أو جلسة نقاش أو ورشة عملية — نفضّل الصيغ الشاملة والعملية.</span>
        </p>
        <a
          href={mail("Cursor Saudi — speaker / topic proposal")}
          class="inline-flex text-sm font-medium text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
        >
          <span class="lang-en">Email your proposal →</span>
          <span class="lang-ar">أرسل اقتراحك بالبريد ←</span>
        </a>
        <div class="mt-4 flex flex-wrap gap-2">
          <a href={discord} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
            <span class="lang-en">Chat on Discord ↗</span>
            <span class="lang-ar">تحدث على ديسكورد ↗</span>
          </a>
          <a href={luma} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
            <span class="lang-en">Upcoming events ↗</span>
            <span class="lang-ar">فعاليات قادمة ↗</span>
          </a>
          <a href={twitter} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
            <span class="lang-en">Follow on X ↗</span>
            <span class="lang-ar">تابعنا على X ↗</span>
          </a>
        </div>
      </div>
    </div>

    <!-- We offer -->
    <div id="we-offer" class="mb-10 scroll-mt-24">
      <h2 class="text-xl font-semibold text-white mb-2">
        <span class="lang-en">We offer</span>
        <span class="lang-ar">ما نقدمه</span>
      </h2>
      <p class="text-sm text-[#8b949e] mb-6 leading-relaxed">
        <span class="lang-en">Commercial and media engagements outside of free community meetups.</span>
        <span class="lang-ar">خدمات تجارية وإعلامية خارج اللقاءات المجتمعية المجانية.</span>
      </p>
      <div class="space-y-4">
        <div class="bg-[#171717] border border-[#252525] rounded-xl p-5 md:p-6">
          <h3 class="text-white font-medium mb-2">
            <span class="lang-en">In-person training</span>
            <span class="lang-ar">تدريب حضوري</span>
          </h3>
          <p class="text-sm text-[#999999] leading-relaxed mb-4">
            <span class="lang-en">Interested in an in-person session for your team on AI-native development and Cursor? Email us with your context — we will follow up to discuss format, audience, and next steps. Scope and commercial details are worked out after we understand what you need.</span>
            <span class="lang-ar">مهتم بجلسة حضورية لفريقك حول التطوير المدعوم بالذكاء الاصطناعي وكيرسر؟ راسلنا بسياقك — نتواصل لمناقشة الصيغة والجمهور والخطوات التالية. نحدد النطاق والتفاصيل التجارية بعد فهم احتياجك.</span>
          </p>
          <a
            href={mail("Cursor Saudi — corporate training inquiry")}
            class="inline-flex text-sm font-medium text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
          >
            <span class="lang-en">Start by email →</span>
            <span class="lang-ar">ابدأ بالبريد ←</span>
          </a>
        </div>
        <div class="bg-[#171717] border border-[#252525] rounded-xl p-5 md:p-6">
          <h3 class="text-white font-medium mb-2">
            <span class="lang-en">Media &amp; interviews</span>
            <span class="lang-ar">الإعلام والمقابلات</span>
          </h3>
          <p class="text-sm text-[#999999] leading-relaxed mb-4">
            <span class="lang-en">If you want us to join your panel, podcast, live stream, or editorial piece — share the outlet, audience, and format.</span>
            <span class="lang-ar">إذا رغبت بمشاركتنا في جلسة أو بودكاست أو بث مباشر أو محتوى تحريري — أرسل الجهة والجمهور والصيغة.</span>
          </p>
          <a
            href={mail("Cursor Saudi — media / interview request")}
            class="inline-flex text-sm font-medium text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
          >
            <span class="lang-en">Invite us →</span>
            <span class="lang-ar">ادعُنا ←</span>
          </a>
          <div class="mt-4 flex flex-wrap gap-2">
            <a href={twitter} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
              <span class="lang-en">Community on X ↗</span>
              <span class="lang-ar">المجتمع على X ↗</span>
            </a>
            <a href={discord} target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#333] bg-[#141414] px-3 py-1.5 text-xs font-medium text-[#b0b0b0] hover:border-white/20 hover:text-white transition-colors">
              <span class="lang-en">Discord ↗</span>
              <span class="lang-ar">ديسكورد ↗</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-[#171717] border border-[#252525] rounded-2xl p-6 md:p-8 space-y-4 text-sm text-[#b0b0b0] leading-relaxed">
      <p>
        <span class="lang-en">For any partnership or support path above, include when you email:</span>
        <span class="lang-ar">لأي مسار شراكة أو دعم أعلاه، أذكر في بريدك:</span>
      </p>
      <ul class="list-disc list-inside space-y-2">
        <li>
          <span class="lang-en">Organization or name and city</span>
          <span class="lang-ar">اسم الجهة أو الشخص والمدينة</span>
        </li>
        <li>
          <span class="lang-en">Which section you are responding to and what you have in mind</span>
          <span class="lang-ar">القسم الذي يهمك وما تود تقديمه أو طلبه</span>
        </li>
        <li>
          <span class="lang-en">A contact person and the best way to reach you</span>
          <span class="lang-ar">جهة اتصال وأفضل وسيلة للتواصل</span>
        </li>
      </ul>
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href={mail("Cursor Saudi — partnership & collaborate")}
        class="btn-primary px-5 py-2.5 rounded-full text-sm font-medium inline-flex items-center justify-center"
      >
        <span class="lang-en">Email {email}</span>
        <span class="lang-ar">راسل {email}</span>
      </a>
      <a href="/about" class="px-5 py-2.5 rounded-full border border-[#333] text-sm text-[#999999] hover:text-white hover:border-white/25 transition-colors">
        <span class="lang-en">← About the community</span>
        <span class="lang-ar">عن المجتمع ←</span>
      </a>
    </div>
  </div>
</section>

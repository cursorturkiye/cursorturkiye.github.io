---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import HomePage from "@/components/HomePage.astro";
import EventsPage from "@/components/EventsPage.astro";
import AlbumsPage from "@/components/AlbumsPage.astro";
import BlogPage from "@/components/BlogPage.astro";
import AboutPage from "@/components/AboutPage.astro";
import ThankYouPage from "@/components/ThankYouPage.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <Header />

  <main class="flex-grow pt-[72px] relative z-10">
    <HomePage />
    <EventsPage />
    <AlbumsPage />
    <BlogPage />
    <AboutPage />
    <ThankYouPage />
  </main>

  <Footer />

  <!-- SPA Page Switching Script -->
  <script is:inline>
    function switchPage(pageId) {
      document.querySelectorAll('.nav-link').forEach(function(link) {
        link.classList.remove('active');
        var linkNav = link.getAttribute('data-nav');
        if (linkNav === pageId || link.id === 'nav-' + pageId) {
          link.classList.add('active');
        }
      });

      document.querySelectorAll('.page-content').forEach(function(section) {
        section.classList.remove('active');
      });

      var selectedSection = document.getElementById(pageId);
      if (selectedSection) {
        selectedSection.classList.add('active');
      }

      // Reset albums to list view when navigating to albums page
      if (pageId === 'albums' && typeof window.__albumsResetToList === 'function') {
        window.__albumsResetToList();
      }

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-nav]').forEach(function(el) {
        el.addEventListener('click', function(e) {
          e.preventDefault();
          var pageId = this.getAttribute('data-nav');
          if (pageId) {
            switchPage(pageId);
          }
        });
      });

      var hash = window.location.hash.replace('#', '');
      switchPage(hash || 'home');
    });
  </script>
</Layout>

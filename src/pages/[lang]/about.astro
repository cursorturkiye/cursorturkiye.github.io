---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import AboutPage from "@/components/AboutPage.astro";
import Footer from "@/components/Footer.astro";
import { SITE_LOCALES } from "@/utils/i18n-path";

export function getStaticPaths() {
  return SITE_LOCALES.map((lang) => ({ params: { lang } }));
}
---

<Layout title="About — Cursor Türkiye">
  <Header />
  <main id="main-content" class="flex-grow pt-[72px] relative z-10">
    <AboutPage />
  </main>
  <Footer />
</Layout>

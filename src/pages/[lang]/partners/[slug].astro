---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getAllPartnersWithEvents } from "@/utils/people";
import { contributorRoleBadgeClass } from "@/utils/contributor-role-badge";
import { getEventIdsWithBlog, eventBlogSlug } from "@/utils/blog";
import { SITE_LOCALES, localizedPath } from "@/utils/i18n-path";

export async function getStaticPaths() {
  const partners = await getAllPartnersWithEvents();
  const paths: { params: { lang: string; slug: string }; props: { partner: (typeof partners)[number] } }[] = [];
  for (const partner of partners) {
    for (const lang of SITE_LOCALES) {
      paths.push({ params: { lang, slug: partner.slug }, props: { partner } });
    }
  }
  return paths;
}

const { partner } = Astro.props;
const pagePath = Astro.url.pathname;
const blogIds = await getEventIdsWithBlog();
const detailParagraphs = partner.detailParagraphs;

const contributorAvatarColors = [
  "from-blue-500/20 to-blue-600/10 text-blue-400",
  "from-purple-500/20 to-purple-600/10 text-purple-400",
  "from-green-500/20 to-green-600/10 text-green-400",
  "from-amber-500/20 to-amber-600/10 text-amber-400",
  "from-rose-500/20 to-rose-600/10 text-rose-400",
  "from-cyan-500/20 to-cyan-600/10 text-cyan-400",
  "from-indigo-500/20 to-indigo-600/10 text-indigo-400",
];

const roleLabel: Record<string, { en: string; tr: string }> = {
  official: { en: "Official Partner", tr: "Türkçe Türkçe" },
  "community-partner": { en: "Community Partner", tr: "Topluluk Ortagi" },
  "venue-host": { en: "Venue Host", tr: "Türkçe" },
  "past-community-partner": { en: "Past Community Partner", tr: "Türkçe Türkçe" },
};

const roleColors: Record<string, string> = {
  official: "text-white bg-white/[0.08] border border-white/[0.15]",
  "community-partner": "text-[#7dd3fc] bg-[#7dd3fc]/[0.08] border border-[#7dd3fc]/[0.15]",
  "venue-host": "text-[#86efac] bg-[#86efac]/[0.08] border border-[#86efac]/[0.15]",
  "past-community-partner": "text-[#6E6E6E] bg-white/[0.03] border border-white/[0.05]",
};

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}

---

<Layout title={`${partner.name} — Cursor Türkiye`}>
  <Header />
  <main id="main-content" class="flex-grow pt-[72px] relative z-10">
    <section class="max-w-4xl mx-auto px-6 md:px-10 py-12 md:py-20">
      <a
        href={localizedPath(pagePath, "/thankyou")}
        class="inline-flex items-center gap-1.5 text-sm text-[#999999] hover:text-white transition-colors mb-8"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span class="lang-en">Back to Thank You</span>
      <span class="lang-tr">Back to Thank You</span>
      </a>

      <!-- Partner header -->
      <div class="flex flex-col sm:flex-row gap-8 items-start mb-12">
        <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-2xl bg-[#141414] border border-[#252525] flex items-center justify-center p-4 shrink-0">
          <img
            src={partner.logo}
            alt={partner.name}
            class="max-h-full max-w-full object-contain object-center"
            loading="eager"
          />
        </div>
        <div class="min-w-0 flex-grow">
          <span class:list={["inline-flex items-center text-[0.7rem] font-semibold uppercase tracking-[0.04em] px-2 py-0.5 rounded mb-3", roleColors[partner.role]]}>
            <span class="lang-en">{roleLabel[partner.role].en}</span>
      <span class="lang-tr">{roleLabel[partner.role].en}</span>
          </span>
          <h1 class="text-3xl md:text-4xl font-semibold text-white mb-3">
            <span class="lang-en">{partner.name}</span>
      <span class="lang-tr">{partner.name}</span>
          </h1>
          <p class="text-[#b0b0b0] leading-relaxed mb-4">
            <span class="lang-en">{partner.description}</span>
      <span class="lang-tr">{partner.description}</span>
          </p>
          <div class="flex flex-wrap items-center gap-4 text-sm">
            <a
              href={partner.url}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-1.5 text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
            >
              <span class="lang-en">Visit website ↗</span>
      <span class="lang-tr">Visit website ↗</span>
            </a>
            {partner.cities.length > 0 && (
              <span class="text-xs text-[#6E6E6E]">{partner.cities.join(", ")}</span>
            )}
          </div>
        </div>
      </div>

      {partner.parentCompany && (
        <div class="mb-10 rounded-xl border border-[#252525] bg-[#171717] p-6 md:p-8">
          <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-4">
            <span class="lang-en">Parent company</span>
      <span class="lang-tr">Parent company</span>
          </h2>
          <a
            href={partner.parentCompany.url}
            target="_blank"
            rel="noreferrer"
            class="text-xl font-semibold text-white hover:text-[#79c0ff] transition-colors inline-flex items-center gap-1.5"
          >
            <span class="lang-en">{partner.parentCompany.name}</span>
      <span class="lang-tr">{partner.parentCompany.name}</span>
            <span class="text-[#58a6ff] text-base" aria-hidden="true">↗</span>
          </a>
          <p class="text-sm text-[#999999] mt-3 leading-relaxed max-w-2xl">
            <span class="lang-en">The team and company behind Cursor.</span>
      <span class="lang-tr">The team and company behind Cursor.</span>
          </p>
        </div>
      )}

      {detailParagraphs && (
        <div class="space-y-5 mb-12 max-w-3xl">
          {detailParagraphs.en.map((para, i) => (
            <p class="text-[#b0b0b0] leading-relaxed text-[0.95rem]">
              <span class="lang-en">{para}</span>
      <span class="lang-tr">{para}</span>
            </p>
          ))}
        </div>
      )}

      {partner.contributors && partner.contributors.length > 0 && (
        <div class="mb-12">
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest">
              <span class="lang-en">Contributors</span>
      <span class="lang-tr">Contributors</span>
            </h2>
            <span class="text-xs text-[#6E6E6E]">
              <span class="lang-en">
                {partner.contributors.length}{" "}
                {partner.contributors.length === 1 ? "person" : "people"}
              </span>
      <span class="lang-tr">
                {partner.contributors.length}{" "}
                {partner.contributors.length === 1 ? "person" : "people"}
              </span>
            </span>
          </div>
          <p class="text-sm text-[#999999] mb-5 leading-relaxed">
            <span class="lang-en">People from {partner.name} who helped make our events happen.</span>
      <span class="lang-tr">People from {partner.name} who helped make our events happen.</span>
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {partner.contributors.map((c, ci) => (
              <div class="bg-[#171717] border border-[#252525] rounded-xl p-6 flex flex-col items-center text-center">
                {c.photo ? (
                  <img
                    src={c.photo}
                    alt=""
                    class="w-32 h-32 md:w-36 md:h-36 rounded-full object-cover border border-[#252525] mb-4"
                    width="144"
                    height="144"
                    loading="lazy"
                  />
                ) : (
                  <div class:list={[
                    "w-32 h-32 md:w-36 md:h-36 rounded-full bg-gradient-to-br flex items-center justify-center text-3xl font-bold border border-white/5 mb-4",
                    contributorAvatarColors[ci % contributorAvatarColors.length],
                  ]}>
                    {c.initials}
                  </div>
                )}
                <h3 class="text-lg font-semibold text-white mb-2">
                  <span class="lang-en">{c.name}</span>
      <span class="lang-tr">{c.name}</span>
                </h3>
                <span
                  class:list={[
                    "inline-flex items-center text-[0.65rem] font-semibold tracking-[0.02em] px-2 py-0.5 rounded mb-4",
                    contributorRoleBadgeClass(c.role),
                  ]}
                >
                  <span class="lang-en">{c.role}</span>
      <span class="lang-tr">{c.role}</span>
                </span>
                {(c.twitter || c.linkedin || c.email) && (
                  <div class="flex gap-4 pt-4 border-t border-[#252525] mt-auto w-full justify-center">
                    {c.twitter && (
                      <a href={c.twitter} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="X / Twitter">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                      </a>
                    )}
                    {c.linkedin && (
                      <a href={c.linkedin} target="_blank" rel="noreferrer" class="text-[#6E6E6E] hover:text-white transition-colors" title="LinkedIn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                      </a>
                    )}
                    {c.email && (
                      <a href={`mailto:${c.email}`} class="text-[#6E6E6E] hover:text-white transition-colors" title="Email">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                      </a>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {!partner.omitEventStats && (
      <div>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest">
            <span class="lang-en">Events</span>
      <span class="lang-tr">Events</span>
          </h2>
          <span class="text-xs text-[#6E6E6E]">
            <span class="lang-en">
              {partner.events.length}{" "}
              {partner.events.length === 1 ? "event" : "events"}
            </span>
      <span class="lang-tr">
              {partner.events.length}{" "}
              {partner.events.length === 1 ? "event" : "events"}
            </span>
          </span>
        </div>
        {partner.events.length === 0 ? (
          <div class="bg-[#171717] border border-dashed border-[#252525] rounded-xl p-6 text-center">
            <p class="text-sm text-[#6E6E6E]">
              <span class="lang-en">No events recorded for this partner yet.</span>
      <span class="lang-tr">No events recorded for this partner yet.</span>
            </p>
          </div>
        ) : (
          <div class="space-y-3">
            {partner.events.map((event) => {
              const hasBlog = blogIds.has(event.id);
              const rawHref = hasBlog ? `/blog/${eventBlogSlug(event.id)}/` : "/events";
              const href = localizedPath(pagePath, rawHref);
              return (
                <a
                  href={href}
                  class="block bg-[#171717] border border-[#252525] rounded-xl p-5 hover:border-[#444] transition-all"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0 flex-grow">
                      <h3 class="text-base font-semibold text-white mb-1">
                        <span class="lang-en">{event.data.title}</span>
      <span class="lang-tr">{event.data.title}</span>
                      </h3>
                      <p class="text-xs text-[#999999] line-clamp-2">
                        <span class="lang-en">{event.data.description}</span>
      <span class="lang-tr">{event.data.description}</span>
                      </p>
                    </div>
                    <div class="text-right shrink-0">
                      <div class="text-[10px] font-mono text-[#6E6E6E] uppercase tracking-widest">
                        {formatDate(event.data.date)}
                      </div>
                      <div class="text-[10px] text-[#6E6E6E] mt-0.5">
                        <span class="lang-en">{event.data.location}</span>
      <span class="lang-tr">{event.data.location}</span>
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
      )}
    </section>
  </main>
  <Footer />
</Layout>

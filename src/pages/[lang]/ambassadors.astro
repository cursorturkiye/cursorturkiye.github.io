---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import AmbassadorsProgramPage from "@/components/AmbassadorsProgramPage.astro";
import Footer from "@/components/Footer.astro";
import { SITE_LOCALES } from "@/utils/i18n-path";

export function getStaticPaths() {
  return SITE_LOCALES.map((lang) => ({ params: { lang } }));
}
---

<Layout title="Become an Ambassador — Cursor Türkiye">
  <Header />
  <main id="main-content" class="flex-grow pt-[72px] relative z-10">
    <AmbassadorsProgramPage />
  </main>
  <Footer />
</Layout>

---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getEventsWithAlbums, getEventImageUrl, isVideo } from "@/utils/events";
import { getEventPartnersMap, getEventPartners, partnerRoleLabels } from "@/utils/people";
import type { EventPartnerEntry } from "@/utils/people";
import { config } from "@/config";
import type { CollectionEntry } from "astro:content";
import { SITE_LOCALES, localizedPath } from "@/utils/i18n-path";

type EventEntry = CollectionEntry<"events">;

export async function getStaticPaths() {
  const albums = await getEventsWithAlbums();
  const paths: { params: { lang: string; slug: string }; props: { event: EventEntry } }[] = [];
  for (const event of albums) {
    for (const lang of SITE_LOCALES) {
      paths.push({ params: { lang, slug: event.id }, props: { event } });
    }
  }
  return paths;
}

const { event } = Astro.props as { event: EventEntry };
const pagePath = Astro.url.pathname;
const partnersMap = getEventPartnersMap();
const eventPartners = getEventPartners(event.id, event.data.venue, partnersMap);

const siteOrigin = Astro.site?.origin ?? "https://cursorturkiye.com";
const pageUrl = new URL(Astro.url.pathname, siteOrigin).href;
const shareText = `${event.data.title} — Cursor Türkiye`;
const xShareUrl = `https://x.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(shareText)}`;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;

type PersonLookup = { nameTr: string; href: string | null };
type PhotoCreditRow = { nameEn: string; nameTr: string; href: string | null };
const personLookup = new Map<string, PersonLookup>();

type SpeakerLookupSource = { name: string; nameTr?: string; slug: string; aliases?: readonly string[] };
for (const speaker of config.speakers as unknown as readonly SpeakerLookupSource[]) {
  const entry: PersonLookup = { nameTr: speaker.nameTr ?? speaker.name, href: `/speakers/${speaker.slug}` };
  personLookup.set(speaker.name, entry);
  for (const alias of speaker.aliases ?? []) personLookup.set(alias, entry);
}

type PartnerContributorSource = { name: string; nameTr?: string };
for (const partner of config.partners) {
  const contributors = "contributors" in partner ? (partner.contributors as readonly PartnerContributorSource[] | undefined) : undefined;
  for (const c of contributors ?? []) {
    if (personLookup.has(c.name)) continue;
    personLookup.set(c.name, { nameTr: c.nameTr ?? c.name, href: `/partners/${partner.slug}` });
  }
}

function resolvePerson(name: string): PersonLookup {
  return personLookup.get(name) ?? { nameTr: name, href: null };
}

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

function formatDateTr(date: Date) {
  return date.toLocaleDateString("tr-TR", { year: "numeric", month: "short", day: "numeric" });
}

function getAllMedia(ev: { data: { photos?: string[]; videos?: string[] } }) {
  return [...(ev.data.photos ?? []), ...(ev.data.videos ?? [])];
}

function joinerEn(idx: number, total: number) {
  if (idx === 0) return "";
  if (idx === total - 1) return total === 2 ? " & " : ", & ";
  return ", ";
}

function joinerTr(idx: number, total: number) {
  if (idx === 0) return "";
  if (idx === total - 1) return " Türkçe";
  return "Türkçe ";
}

const media = getAllMedia(event);
const photographers: PhotoCreditRow[] = (event.data.photographers ?? []).map((name: string) => ({
  nameEn: name,
  ...resolvePerson(name),
}));
---

<Layout
  title={`${event.data.title} Album — Cursor Türkiye`}
  description={event.data.description}
>
  <Header />

  <main id="main-content" class="flex-grow pt-[72px] relative z-10">
    <section id="album-detail">
      <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">
        <a href={localizedPath(pagePath, "/albums/")} class="inline-flex items-center gap-2 text-sm text-[#999999] hover:text-white transition-colors mb-8">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span class="lang-en">Back to Albums</span>
      <span class="lang-tr">Back to Albums</span>
        </a>

        <div class="mb-10 border-b border-[#252525] pb-8">
          <h1 class="text-3xl md:text-4xl font-semibold text-white mb-3">
            <span class="lang-en">{event.data.title}</span>
      <span class="lang-tr">{event.data.title}</span>
          </h1>
          <div class="flex flex-wrap items-center gap-4 text-sm text-[#999999] mb-4">
            <span class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span class="lang-en">{formatDate(event.data.date)}</span>
      <span class="lang-tr">{formatDate(event.data.date)}</span>
            </span>
            <span class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span class="lang-en">{event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
      <span class="lang-tr">{event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
            </span>
            {eventPartners.length > 0 && (
              <span class="flex flex-wrap items-center gap-2">
                {eventPartners.map((p: EventPartnerEntry) => (
                  <a href={localizedPath(pagePath, `/partners/${p.slug}/`)} class="flex items-center gap-1.5 rounded-full bg-white/5 border border-[#252525] px-2.5 py-1 hover:border-[#444] transition-colors">
                    <img src={p.logo} alt={p.name} class="w-5 h-5 object-contain" width="20" height="20" loading="lazy" />
                    <span class="text-[10px] text-[#8b949e] leading-tight">
                      <span class="lang-en">{partnerRoleLabels[p.role].en}</span>
      <span class="lang-tr">{partnerRoleLabels[p.role].en}</span>
                    </span>
                  </a>
                ))}
              </span>
            )}
            <span class="flex items-center gap-2 ms-auto">
              <a href={xShareUrl} target="_blank" rel="noreferrer" class="w-8 h-8 flex items-center justify-center rounded-full bg-white/5 border border-[#252525] text-[#6E6E6E] hover:text-white hover:border-[#444] transition-colors" aria-label="Share on X">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href={linkedInShareUrl} target="_blank" rel="noreferrer" class="w-8 h-8 flex items-center justify-center rounded-full bg-white/5 border border-[#252525] text-[#6E6E6E] hover:text-white hover:border-[#444] transition-colors" aria-label="Share on LinkedIn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </span>
          </div>
          <p class="text-[#999999] max-w-2xl">
            <span class="lang-en">{event.data.description}</span>
      <span class="lang-tr">{event.data.description}</span>
          </p>
        </div>

        {photographers.length > 0 && (
          <div class="flex items-center gap-2 text-xs text-[#999999] mb-4">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <span class="lang-en">
              Photos by{" "}
              {photographers.map((p: PhotoCreditRow, i: number) => (
                <>
                  {joinerEn(i, photographers.length)}
                  {p.href ? (
                    <a href={localizedPath(pagePath, p.href)} class="text-[#58a6ff] hover:text-[#79c0ff] transition-colors">{p.nameEn}</a>
                  ) : (
                    <span>{p.nameEn}</span>
                  )}
                </>
              ))}
            </span>
            <span class="lang-tr">
              Türkçe:{" "}
              {photographers.map((p: PhotoCreditRow, i: number) => (
                <>
                  {joinerTr(i, photographers.length)}
                  {p.href ? (
                    <a href={localizedPath(pagePath, p.href)} class="text-[#58a6ff] hover:text-[#79c0ff] transition-colors">{p.nameTr}</a>
                  ) : (
                    <span>{p.nameTr}</span>
                  )}
                </>
              ))}
            </span>
          </div>
        )}

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
          {media.map((filename, idx) => {
            const src = getEventImageUrl(event.id, filename);
            const mediaIsVideo = isVideo(filename);
            return (
              <button
                class="album-media aspect-square bg-[#1F1F1F] rounded-xl overflow-hidden cursor-pointer border border-[#252525] hover:border-white/20 transition-all group relative"
                data-event-id={event.id}
                data-media-idx={idx}
                data-media-type={mediaIsVideo ? "video" : "image"}
                type="button"
              >
                {mediaIsVideo ? (
                  <>
                    <video
                      src={src}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      preload="metadata"
                      muted
                    />
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                      <div class="w-12 h-12 rounded-full bg-black/60 flex items-center justify-center">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                          <polygon points="6,3 20,12 6,21"/>
                        </svg>
                      </div>
                    </div>
                  </>
                ) : (
                  <img
                    src={src}
                    alt={`${event.data.title} - ${idx + 1}`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                )}
              </button>
            );
          })}
        </div>
      </div>

      <!-- Lightbox -->
      <div id="album-lightbox" class="fixed inset-0 z-[100] hidden bg-black/90 backdrop-blur-sm overflow-x-hidden overflow-y-auto overscroll-contain">
        <div id="lightbox-backdrop" class="fixed inset-0 z-0" aria-hidden="true"></div>
        <div class="relative z-[1] flex min-h-[100dvh] w-full items-center justify-center px-4 py-20 sm:px-6 sm:py-24 box-border pointer-events-none">
          <img
            id="lightbox-img"
            class="relative z-[1] max-h-[min(85dvh,calc(100dvh-8rem))] max-w-[min(90vw,100%)] w-auto h-auto min-h-0 min-w-0 object-contain rounded-lg hidden shadow-2xl pointer-events-auto"
            src=""
            alt=""
          />
          <video
            id="lightbox-video"
            class="relative z-[1] max-h-[min(85dvh,calc(100dvh-8rem))] max-w-[min(90vw,100%)] w-auto h-auto min-h-0 min-w-0 object-contain rounded-lg hidden shadow-2xl pointer-events-auto"
            controls
            playsinline
          ></video>
        </div>
        <button id="lightbox-close" class="fixed top-4 end-4 z-[2] w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button id="lightbox-prev" class="fixed start-4 top-1/2 -translate-y-1/2 z-[2] w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button id="lightbox-next" class="fixed end-4 top-1/2 -translate-y-1/2 z-[2] w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <div
          id="lightbox-footer"
          class="fixed bottom-4 left-1/2 -translate-x-1/2 z-[2] flex flex-col items-center gap-2 sm:flex-row sm:gap-4 pointer-events-none max-w-[calc(100vw-2rem)]"
        >
          <div id="lightbox-counter" class="text-sm text-white/70 whitespace-nowrap"></div>
          <button
            id="lightbox-copy-link"
            type="button"
            class="pointer-events-auto text-xs font-medium px-3 py-1.5 rounded-lg border border-white/20 bg-white/10 text-white hover:bg-white/15 hover:border-white/30 transition-colors shrink-0"
          >
            <span class="lang-en">Copy link to this photo</span>
      <span class="lang-tr">Copy link to this photo</span>
          </button>
        </div>
        <p id="lightbox-copy-status" class="sr-only" role="status" aria-live="polite"></p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  (function () {
    var lightbox = document.getElementById('album-lightbox');
    var lightboxImg = document.getElementById('lightbox-img');
    var lightboxVideo = document.getElementById('lightbox-video');
    var lightboxCounter = document.getElementById('lightbox-counter');
    var copyLinkBtn = document.getElementById('lightbox-copy-link');
    var copyStatus = document.getElementById('lightbox-copy-status');
    var currentMedia = [];
    var currentIdx = 0;
    /** True after we `pushState` opening the lightbox so Back / close use `history.back()`. */
    var lightboxSessionPushed = false;

    function setPhotoInUrl(oneBasedOrNull) {
      try {
        var u = new URL(window.location.href);
        if (oneBasedOrNull == null) u.searchParams.delete('photo');
        else u.searchParams.set('photo', String(oneBasedOrNull));
        var next = u.pathname + u.search + u.hash;
        var cur = window.location.pathname + window.location.search + window.location.hash;
        if (next !== cur) history.replaceState(null, '', next);
      } catch (e) {}
    }

    /** Updates `?photo=` on the current history entry while the lightbox is open (prev/next). */
    function replacePhotoInCurrentEntry() {
      if (!lightbox || lightbox.classList.contains('hidden') || !currentMedia.length) return;
      try {
        var u = new URL(window.location.href);
        u.searchParams.set('photo', String(currentIdx + 1));
        var next = u.pathname + u.search + u.hash;
        var cur = window.location.pathname + window.location.search + window.location.hash;
        if (next !== cur) history.replaceState({ albumLightbox: true }, '', next);
      } catch (e) {}
    }

    /**
     * After the lightbox is shown: push a history entry when opening from the grid so Back closes it.
     * Skips push when the URL already matches (e.g. shared deep link).
     */
    function commitPhotoAfterOpen() {
      if (!lightbox || lightbox.classList.contains('hidden') || !currentMedia.length) return;
      try {
        var u = new URL(window.location.href);
        u.searchParams.set('photo', String(currentIdx + 1));
        var next = u.pathname + u.search + u.hash;
        var cur = window.location.pathname + window.location.search + window.location.hash;
        if (next === cur) {
          lightboxSessionPushed = false;
          return;
        }
        history.pushState({ albumLightbox: true }, '', next);
        lightboxSessionPushed = true;
      } catch (e) {}
    }

    function closeLightboxVisual() {
      if (lightbox) lightbox.classList.add('hidden');
      document.body.style.overflow = '';
      if (lightboxVideo) {
        lightboxVideo.pause();
        lightboxVideo.removeAttribute('src');
      }
    }

    /** Remove `photo` only when it is not a positive integer (out-of-range is clamped on open). */
    function stripMalformedPhotoQuery() {
      try {
        var u = new URL(window.location.href);
        var raw = u.searchParams.get('photo');
        if (raw == null) return;
        var n = parseInt(raw, 10);
        if (!isFinite(n) || n < 1) {
          u.searchParams.delete('photo');
          history.replaceState(null, '', u.pathname + u.search + u.hash);
        }
      } catch (e) {}
    }

    /** If `?photo=` exceeds album length, normalize with replaceState before deep-link open. */
    function clampPhotoQueryToAlbumSize() {
      try {
        var u = new URL(window.location.href);
        var raw = u.searchParams.get('photo');
        if (raw == null) return;
        var n = parseInt(raw, 10);
        var first = document.querySelector('.album-media');
        if (!first) return;
        var eventId = first.getAttribute('data-event-id');
        if (!eventId) return;
        var count = document.querySelectorAll('.album-media[data-event-id="' + eventId + '"]').length;
        if (!isFinite(n) || count === 0) return;
        if (n > count) {
          u.searchParams.set('photo', String(count));
          history.replaceState(null, '', u.pathname + u.search + u.hash);
        }
      } catch (e) {}
    }

    function openLightbox(eventId, idx) {
      var items = document.querySelectorAll('.album-media[data-event-id="' + eventId + '"]');
      currentMedia = [];
      items.forEach(function (el) {
        var type = el.getAttribute('data-media-type');
        var mediaEl = type === 'video' ? el.querySelector('video') : el.querySelector('img');
        if (mediaEl) {
          currentMedia.push({ src: mediaEl.getAttribute('src'), type: type });
        }
      });
      if (currentMedia.length === 0) return;
      currentIdx = idx;
      if (currentIdx < 0) currentIdx = 0;
      if (currentIdx >= currentMedia.length) currentIdx = currentMedia.length - 1;
      updateLightbox();
      if (lightbox) lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      commitPhotoAfterOpen();
    }

    function closeLightbox() {
      if (lightboxSessionPushed) {
        lightboxSessionPushed = false;
        history.back();
        return;
      }
      setPhotoInUrl(null);
      closeLightboxVisual();
    }

    function updateLightbox() {
      var item = currentMedia[currentIdx];
      if (!item) return;
      if (item.type === 'video') {
        if (lightboxImg) lightboxImg.classList.add('hidden');
        if (lightboxVideo) {
          lightboxVideo.classList.remove('hidden');
          lightboxVideo.setAttribute('src', item.src);
          lightboxVideo.load();
        }
      } else {
        if (lightboxVideo) { lightboxVideo.pause(); lightboxVideo.classList.add('hidden'); }
        if (lightboxImg) {
          lightboxImg.classList.remove('hidden');
          lightboxImg.setAttribute('src', item.src);
          lightboxImg.setAttribute('alt', 'Media ' + (currentIdx + 1));
        }
      }
      if (lightboxCounter) lightboxCounter.textContent = (currentIdx + 1) + ' / ' + currentMedia.length;
      replacePhotoInCurrentEntry();
    }

    function nextMedia() { if (lightboxVideo) lightboxVideo.pause(); currentIdx = (currentIdx + 1) % currentMedia.length; updateLightbox(); }
    function prevMedia() { if (lightboxVideo) lightboxVideo.pause(); currentIdx = (currentIdx - 1 + currentMedia.length) % currentMedia.length; updateLightbox(); }

    function tryOpenFromQuery() {
      var first = document.querySelector('.album-media');
      if (!first) return;
      var eventId = first.getAttribute('data-event-id');
      if (!eventId) return;
      var raw = new URLSearchParams(window.location.search).get('photo');
      if (raw == null) return;
      var n = parseInt(raw, 10);
      var count = document.querySelectorAll('.album-media[data-event-id="' + eventId + '"]').length;
      if (!isFinite(n) || n < 1 || count === 0) return;
      var idx0 = Math.min(n, count) - 1;
      openLightbox(eventId, idx0);
    }

    document.querySelectorAll('.album-media').forEach(function (el) {
      el.addEventListener('click', function () {
        openLightbox(this.getAttribute('data-event-id'), parseInt(this.getAttribute('data-media-idx'), 10));
      });
    });

    var closeBtn = document.getElementById('lightbox-close');
    var prevBtn = document.getElementById('lightbox-prev');
    var nextBtn = document.getElementById('lightbox-next');
    var backdropEl = document.getElementById('lightbox-backdrop');
    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (prevBtn) prevBtn.addEventListener('click', prevMedia);
    if (nextBtn) nextBtn.addEventListener('click', nextMedia);
    if (backdropEl) backdropEl.addEventListener('click', closeLightbox);

    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', function () {
        var href = window.location.href;
        var ar = document.documentElement.getAttribute('lang') === 'tr';
        function announce(msg) {
          if (copyStatus) copyStatus.textContent = msg;
          window.setTimeout(function () { if (copyStatus) copyStatus.textContent = ''; }, 2500);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(href).then(function () {
            announce(ar ? 'Türkçe Türkçe Türkçe' : 'Link copied');
          }).catch(function () {
            announce(ar ? 'Türkçe Türkçe Türkçe Türkçe Türkçe' : 'Copy the URL from the address bar');
          });
        } else {
          announce(ar ? 'Türkçe Türkçe Türkçe Türkçe Türkçe' : 'Copy the URL from the address bar');
        }
      });
    }

    document.addEventListener('keydown', function (e) {
      if (lightbox && !lightbox.classList.contains('hidden')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') nextMedia();
        if (e.key === 'ArrowLeft') prevMedia();
      }
    });

    window.addEventListener('popstate', function () {
      if (lightbox && !lightbox.classList.contains('hidden')) closeLightboxVisual();
      lightboxSessionPushed = false;
    });

    stripMalformedPhotoQuery();
    clampPhotoQueryToAlbumSize();
    tryOpenFromQuery();
  })();
</script>

---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getAllPartnersWithEvents } from "@/utils/people";
import { getEventIdsWithBlog, eventBlogSlug } from "@/utils/blog";

export async function getStaticPaths() {
  const partners = await getAllPartnersWithEvents();
  return partners.map((partner) => ({
    params: { slug: partner.slug },
    props: { partner },
  }));
}

const { partner } = Astro.props;
const blogIds = await getEventIdsWithBlog();

const roleLabel: Record<string, { en: string; ar: string }> = {
  official: { en: "Official Partner", ar: "الشريك الرسمي" },
  "community-partner": { en: "Community Partner", ar: "شريك مجتمعي" },
  "venue-host": { en: "Venue Host", ar: "مستضيف" },
  "past-community-partner": { en: "Past Community Partner", ar: "شريك سابق" },
};

const roleColors: Record<string, string> = {
  official: "text-white bg-white/[0.08] border border-white/[0.15]",
  "community-partner": "text-[#7dd3fc] bg-[#7dd3fc]/[0.08] border border-[#7dd3fc]/[0.15]",
  "venue-host": "text-[#86efac] bg-[#86efac]/[0.08] border border-[#86efac]/[0.15]",
  "past-community-partner": "text-[#6E6E6E] bg-white/[0.03] border border-white/[0.05]",
};

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}
---

<Layout title={`${partner.name} — Cursor Saudi`}>
  <Header />
  <main class="flex-grow pt-[72px] relative z-10">
    <section class="max-w-4xl mx-auto px-6 md:px-10 py-12 md:py-20">
      <a
        href="/thankyou"
        class="inline-flex items-center gap-1.5 text-sm text-[#999999] hover:text-white transition-colors mb-8"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span class="lang-en">Back to Thank You</span>
        <span class="lang-ar">العودة إلى صفحة الشكر</span>
      </a>

      <!-- Partner header -->
      <div class="flex flex-col sm:flex-row gap-8 items-start mb-12">
        <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-2xl bg-[#141414] border border-[#252525] flex items-center justify-center p-4 shrink-0">
          <img
            src={partner.logo}
            alt={partner.name}
            class="max-h-full max-w-full object-contain object-center"
            loading="eager"
          />
        </div>
        <div class="min-w-0 flex-grow">
          <span class:list={["inline-flex items-center text-[0.7rem] font-semibold uppercase tracking-[0.04em] px-2 py-0.5 rounded mb-3", roleColors[partner.role]]}>
            <span class="lang-en">{roleLabel[partner.role].en}</span>
            <span class="lang-ar">{roleLabel[partner.role].ar}</span>
          </span>
          <h1 class="text-3xl md:text-4xl font-semibold text-white mb-3">
            <span class="lang-en">{partner.name}</span>
            <span class="lang-ar">{partner.nameAr}</span>
          </h1>
          <p class="text-[#b0b0b0] leading-relaxed mb-4">
            <span class="lang-en">{partner.description}</span>
            <span class="lang-ar">{partner.descriptionAr}</span>
          </p>
          <div class="flex flex-wrap items-center gap-4 text-sm">
            <a
              href={partner.url}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-1.5 text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
            >
              <span class="lang-en">Visit website ↗</span>
              <span class="lang-ar">زر الموقع ↗</span>
            </a>
            {partner.cities.length > 0 && (
              <span class="text-xs text-[#6E6E6E]">{partner.cities.join(", ")}</span>
            )}
          </div>
        </div>
      </div>

      <!-- Events -->
      <div>
        <div class="flex items-baseline justify-between mb-4">
          <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest">
            <span class="lang-en">Events</span>
            <span class="lang-ar">الفعاليات</span>
          </h2>
          <span class="text-xs text-[#6E6E6E]">
            <span class="lang-en">
              {partner.events.length}{" "}
              {partner.events.length === 1 ? "event" : "events"}
            </span>
            <span class="lang-ar">{partner.events.length} فعاليات</span>
          </span>
        </div>
        {partner.events.length === 0 ? (
          <div class="bg-[#171717] border border-dashed border-[#252525] rounded-xl p-6 text-center">
            <p class="text-sm text-[#6E6E6E]">
              <span class="lang-en">No events recorded for this partner yet.</span>
              <span class="lang-ar">لا توجد فعاليات مسجلة لهذا الشريك بعد.</span>
            </p>
          </div>
        ) : (
          <div class="space-y-3">
            {partner.events.map((event) => {
              const hasBlog = blogIds.has(event.id);
              const href = hasBlog ? `/blog/${eventBlogSlug(event.id)}/` : "/events";
              return (
                <a
                  href={href}
                  class="block bg-[#171717] border border-[#252525] rounded-xl p-5 hover:border-[#444] transition-all"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0 flex-grow">
                      <h3 class="text-base font-semibold text-white mb-1">
                        <span class="lang-en">{event.data.title}</span>
                        <span class="lang-ar">{event.data.titleAr ?? event.data.title}</span>
                      </h3>
                      <p class="text-xs text-[#999999] line-clamp-2">
                        <span class="lang-en">{event.data.description}</span>
                        <span class="lang-ar">{event.data.descriptionAr ?? event.data.description}</span>
                      </p>
                    </div>
                    <div class="text-right shrink-0">
                      <div class="text-[10px] font-mono text-[#6E6E6E] uppercase tracking-widest">
                        {formatDate(event.data.date)}
                      </div>
                      <div class="text-[10px] text-[#6E6E6E] mt-0.5">
                        <span class="lang-en">{event.data.location}</span>
                        <span class="lang-ar">{event.data.locationAr ?? event.data.location}</span>
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

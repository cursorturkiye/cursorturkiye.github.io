---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getAllSpeakers } from "@/utils/people";
import { getEventIdsWithBlog, eventBlogSlug } from "@/utils/blog";

export async function getStaticPaths() {
  const speakers = await getAllSpeakers();
  return speakers.map((speaker) => ({
    params: { slug: speaker.slug },
    props: { speaker },
  }));
}

const { speaker } = Astro.props;
const blogIds = await getEventIdsWithBlog();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
}
---

<Layout title={`${speaker.name} — Cursor Saudi`}>
  <Header />
  <main class="flex-grow pt-[72px] relative z-10">
    <section class="max-w-4xl mx-auto px-6 md:px-10 py-12 md:py-20">
      <a
        href="/thankyou"
        class="inline-flex items-center gap-1.5 text-sm text-[#999999] hover:text-white transition-colors mb-8"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        <span class="lang-en">Back to Thank You</span>
        <span class="lang-ar">العودة إلى صفحة الشكر</span>
      </a>

      <!-- Profile header -->
      <div class="flex flex-col sm:flex-row gap-8 items-start mb-12">
        {speaker.photo ? (
          <img
            src={speaker.photo}
            alt={speaker.name}
            class="w-32 h-32 sm:w-40 sm:h-40 rounded-full object-cover border-2 border-[#252525] shrink-0"
            loading="eager"
          />
        ) : (
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full bg-[#171717] border-2 border-[#252525] flex items-center justify-center text-3xl font-bold text-white/60 shrink-0">
            {speaker.initials}
          </div>
        )}
        <div class="min-w-0 flex-grow">
          <div class="text-[10px] font-mono uppercase tracking-widest text-[#6E6E6E] mb-2">
            {speaker.isAmbassador ? (
              <>
                <span class="lang-en">Ambassador · Speaker</span>
                <span class="lang-ar">سفير · متحدث</span>
              </>
            ) : (
              <>
                <span class="lang-en">Speaker</span>
                <span class="lang-ar">متحدث</span>
              </>
            )}
          </div>
          <h1 class="text-3xl md:text-4xl font-semibold text-white mb-2">
            <span class="lang-en">{speaker.name}</span>
            <span class="lang-ar">{speaker.nameAr ?? speaker.name}</span>
          </h1>
          <div class="text-sm text-[#999999] mb-4">
            <span class="lang-en">
              {speaker.events.length}{" "}
              {speaker.events.length === 1 ? "talk" : "talks"} given
            </span>
            <span class="lang-ar">{speaker.events.length} حديث</span>
          </div>
          <div class="flex flex-wrap gap-3">
            {speaker.twitter && (
              <a
                href={speaker.twitter}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-[#999999] hover:text-white transition-colors"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                {speaker.twitterHandle ? `@${speaker.twitterHandle}` : "X"}
              </a>
            )}
            {speaker.linkedin && (
              <a
                href={speaker.linkedin}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-[#999999] hover:text-white transition-colors"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            )}
            {speaker.email && (
              <a
                href={`mailto:${speaker.email}`}
                class="inline-flex items-center gap-1.5 text-sm text-[#999999] hover:text-white transition-colors"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                {speaker.email}
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Bio -->
      {(speaker.bio || speaker.bioAr) ? (
        <div class="bg-[#171717] border border-[#252525] rounded-2xl p-6 md:p-8 mb-12">
          <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-3">
            <span class="lang-en">About</span>
            <span class="lang-ar">نبذة</span>
          </h2>
          <p class="text-[#b0b0b0] leading-relaxed">
            <span class="lang-en">{speaker.bio || speaker.bioAr}</span>
            <span class="lang-ar">{speaker.bioAr || speaker.bio}</span>
          </p>
        </div>
      ) : null}

      <!-- Talks -->
      <div>
        <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-4">
          <span class="lang-en">Talks &amp; events</span>
          <span class="lang-ar">المحادثات والفعاليات</span>
        </h2>
        {speaker.events.length === 0 ? (
          <p class="text-sm text-[#6E6E6E]">
            <span class="lang-en">No events yet.</span>
            <span class="lang-ar">لا توجد فعاليات بعد.</span>
          </p>
        ) : (
          <div class="space-y-3">
            {speaker.events.map((event) => {
              const hasBlog = blogIds.has(event.id);
              const href = hasBlog ? `/blog/${eventBlogSlug(event.id)}/` : "/events";
              return (
                <a
                  href={href}
                  class="block bg-[#171717] border border-[#252525] rounded-xl p-5 hover:border-[#444] transition-all"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0 flex-grow">
                      <h3 class="text-base font-semibold text-white mb-1">
                        <span class="lang-en">{event.data.title}</span>
                        <span class="lang-ar">{event.data.titleAr ?? event.data.title}</span>
                      </h3>
                      <p class="text-xs text-[#999999] line-clamp-2">
                        <span class="lang-en">{event.data.description}</span>
                        <span class="lang-ar">{event.data.descriptionAr ?? event.data.description}</span>
                      </p>
                    </div>
                    <div class="text-right shrink-0">
                      <div class="text-[10px] font-mono text-[#6E6E6E] uppercase tracking-widest">
                        {formatDate(event.data.date)}
                      </div>
                      <div class="text-[10px] text-[#6E6E6E] mt-0.5">
                        <span class="lang-en">{event.data.location}</span>
                        <span class="lang-ar">{event.data.locationAr ?? event.data.location}</span>
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

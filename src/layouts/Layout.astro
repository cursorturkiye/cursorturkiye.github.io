---
import { config } from "@/config";
import "@/styles/global.css";
import { localeFromPathname, stripLocalePrefix, pathForLocale } from "@/utils/i18n-path";

interface Props {
  title?: string;
  description?: string;
}

const { title = config.title, description = config.description } = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://cursorturkiye.com";
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const pageLocale = localeFromPathname(Astro.url.pathname);
const htmlLang = pageLocale;
const htmlDir = "ltr";
const ogLocale = pageLocale === "tr" ? "tr_TR" : "en_US";

const stripped = stripLocalePrefix(Astro.url.pathname);
const pathForAlternates = stripped === "/" ? "/" : stripped.endsWith("/") ? stripped : `${stripped}/`;
const hreflangTr = new URL(pathForLocale("tr", pathForAlternates), siteOrigin).href;
const hreflangEn = new URL(pathForLocale("en", pathForAlternates), siteOrigin).href;
---

<!doctype html>
<html lang={htmlLang} dir={htmlDir} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={config.author} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="tr" href={hreflangTr} />
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="x-default" href={hreflangTr} />
    <meta name="theme-color" content="#0F0F0F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <!-- Prevent FOUC: set language before render (single source: public/toggle-lang.js) -->
    <script is:inline src="/toggle-lang.js"></script>
  </head>
  <body class="min-h-screen flex flex-col relative">
    <a href="#main-content" class="skip-link">
      <span class="lang-en">Skip to content</span>
      <span class="lang-tr">Skip to content</span>
    </a>

    <!-- Grid background -->
    <div class="grid-bg" aria-hidden="true"></div>

    <slot />

    <!-- Scroll animation observer -->
    <script is:inline>
      (function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
        );
        document.querySelectorAll(".animate-on-scroll").forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>

